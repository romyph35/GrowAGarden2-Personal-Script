local function rebuildPicker()
	for _, c in ipairs(PickerScroll:GetChildren()) do
		if c:IsA("GuiObject") and not c:IsA("UIListLayout") then
			c:Destroy()
		end
	end
	local guiLots = scanGuiLots()
	if #guiLots == 0 then
		local e = Instance.new("TextLabel")
		e.BackgroundTransparency = 1
		e.Size = UDim2.new(1, 0, 0, 44)
		e.Font = Enum.Font.Gotham
		e.TextSize = 11
		e.TextWrapped = true
		e.TextColor3 = C.textDim
		e.Text = "Open Auction UI first (talk to Auctioneer)"
		e.Parent = PickerScroll
		PickerScroll.CanvasSize = UDim2.new(0, 0, 0, 48)
		return
	end
	for i = 1, #guiLots do
		local guiLot = guiLots[i]
		local row = Instance.new("Frame")
		row.Size = UDim2.new(1, -4, 0, 36)
		row.BackgroundColor3 = C.input
		row.LayoutOrder = i
		row.Parent = PickerScroll
		corner(row, 6)

		local suffix = ""
		if not guiLot.available then
			suffix = " (sold out)"
		end
		local shownPrice = guiLot.priceText
		if shownPrice == "" then
			shownPrice = "?"
		end

		local infoBtn = Instance.new("TextButton")
		infoBtn.BackgroundTransparency = 1
		infoBtn.Size = UDim2.new(0.68, 0, 1, 0)
		infoBtn.Font = Enum.Font.Gotham
		infoBtn.TextSize = 11
		infoBtn.TextXAlignment = Enum.TextXAlignment.Left
		if guiLot.available then
			infoBtn.TextColor3 = C.text
		else
			infoBtn.TextColor3 = C.textDim
		end
		infoBtn.Text = "  " .. guiLot.itemName .. "  -  " .. shownPrice .. suffix .. "  [" .. guiLot.lotId .. "]"
		infoBtn.Parent = row

		local addFromPick = Instance.new("TextButton")
		addFromPick.Size = UDim2.new(0, 56, 0, 28)
		addFromPick.Position = UDim2.new(1, -60, 0.5, -14)
		addFromPick.BackgroundColor3 = C.success
		addFromPick.Font = Enum.Font.GothamMedium
		addFromPick.TextSize = 11
		addFromPick.TextColor3 = C.text
		addFromPick.Text = "Add"
		addFromPick.Parent = row
		corner(addFromPick, 6)

		infoBtn.MouseButton1Click:Connect(function()
			ItemInput.Text = guiLot.itemName
			if guiLot.price > 0 then
				PriceInput.Text = formatPrice(guiLot.price)
			end
		end)

		addFromPick.MouseButton1Click:Connect(function()
			ItemInput.Text = guiLot.itemName
			local inputPrice = parsePrice(PriceInput.Text)
			local usePrice = inputPrice
			if usePrice <= 0 and guiLot.price > 0 then
				usePrice = guiLot.price
			end
			if addWatchlistItem(guiLot.itemName, usePrice) then
				rebuildWatchlistUI()
			end
		end)
	end
	PickerScroll.CanvasSize = UDim2.new(0, 0, 0, PickerLayout.AbsoluteContentSize.Y + 6)
end

PickBtn.MouseButton1Click:Connect(function()
	Picker.Visible = not Picker.Visible
	if Picker.Visible then
		rebuildPicker()
	end
end)

