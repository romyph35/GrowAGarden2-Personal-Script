local function serverNow()
	local ok, t = pcall(function()
		return workspace:GetServerTimeNow()
	end)
	if ok then
		return t
	end
	return os.time()
end

local function parsePrice(text)
	if typeof(text) ~= "string" then
		return 0
	end
	text = text:gsub(",", ""):gsub("%s", "")
	text = text:gsub("\194\162", ""):gsub("¢", ""):gsub("$", "")
	text = text:upper()
	local mult = { K = 1e3, M = 1e6, B = 1e9, T = 1e12 }
	local num, suffix = text:match("([%d]+%.?[%d]*)([KMBT]?)")
	if num then
		return math.floor((tonumber(num) or 0) * (mult[suffix or ""] or 1))
	end
	return tonumber(text) or 0
end

local function formatPrice(price)
	if price >= 1e12 then
		return string.format("%.2fT", price / 1e12)
	end
	if price >= 1e9 then
		return string.format("%.2fB", price / 1e9)
	end
	if price >= 1e6 then
		return string.format("%.2fM", price / 1e6)
	end
	if price >= 1e3 then
		return string.format("%.2fK", price / 1e3)
	end
	return tostring(math.floor(price))
end

local function normalizeName(name)
	if typeof(name) ~= "string" then
		return ""
	end
	return name:lower():gsub("%s+", " ")
end

local function hasFire(obj)
	return type(obj) == "table" and type(rawget(obj, "Fire")) == "function"
end

local function isAuctioneerNetTable(t)
	if type(t) ~= "table" then
		return false
	end
	if not hasFire(rawget(t, "PurchaseLot")) then
		return false
	end
	if not hasFire(rawget(t, "RequestSnapshot")) then
		return false
	end
	if not hasFire(rawget(t, "Snapshot")) then
		return false
	end
	return true
end

local function isFullNetworkingTable(t)
	if type(t) ~= "table" then
		return false
	end
	if not isAuctioneerNetTable(rawget(t, "Auctioneer")) then
		return false
	end
	if type(rawget(t, "Garden")) ~= "table" then
		return false
	end
	if type(rawget(t, "SeedShop")) ~= "table" then
		return false
	end
	return true
end

local function findAuctioneerViaUpvalues()
	if typeof(getgc_fn) ~= "function" or type(debug_getupvalue) ~= "function" then
		return nil
	end
	local function scanFunction(obj)
		for i = 1, 60 do
			local ok, upname, val = pcall(debug_getupvalue, obj, i)
			if not ok or upname == nil then
				break
			end
			if upname == "Networking" and type(val) == "table" then
				local auctioneer = rawget(val, "Auctioneer")
				if isAuctioneerNetTable(auctioneer) then
					return auctioneer
				end
			end
		end
		return nil
	end
	if type(debug_info) == "function" then
		for _, obj in getgc_fn(true) do
			if type(obj) == "function" then
				local ok, name = pcall(debug_info, obj, "n")
				if ok and (name == "buyLot" or name == "setup" or name == "applySnapshot") then
					local found = scanFunction(obj)
					if found then
						return found
					end
				end
			end
		end
	end
	for _, obj in getgc_fn(true) do
		if type(obj) == "function" then
			local found = scanFunction(obj)
			if found then
				return found
			end
		end
	end
	return nil
end

local function findAuctioneerNetInMemory()
	if typeof(getgc_fn) ~= "function" then
		return nil
	end
	for _, obj in getgc_fn(true) do
		if type(obj) == "table" then
			if isFullNetworkingTable(obj) then
				return rawget(obj, "Auctioneer")
			end
			local nested = rawget(obj, "Auctioneer")
			if isAuctioneerNetTable(nested) then
				return nested
			end
			if isAuctioneerNetTable(obj) then
				return obj
			end
		end
	end
	return nil
end

local function findBuyLotFunction()
	if buyLotFn then
		return buyLotFn
	end
	if typeof(getgc_fn) ~= "function" or type(debug_info) ~= "function" then
		return nil
	end
	for _, obj in getgc_fn(true) do
		if type(obj) == "function" then
			local ok, name = pcall(debug_info, obj, "n")
			if ok and name == "buyLot" then
				buyLotFn = obj
				return obj
			end
		end
	end
	return nil
end

local function tryLoadFlagsFromMemory()
	if typeof(getgc_fn) ~= "function" then
		return
	end
	for _, obj in getgc_fn(true) do
		if type(obj) == "table" then
			local debounce = rawget(obj, "PurchaseDebounceSeconds")
			local cooldown = rawget(obj, "PurchaseCooldownSeconds")
			if type(debounce) == "table" and type(debounce.Get) == "function"
				and type(cooldown) == "table" and type(cooldown.Get) == "function" then
				local okD, d = pcall(function()
					return debounce:Get()
				end)
				local okC, c = pcall(function()
					return cooldown:Get()
				end)
				if okD and type(d) == "number" then
					PURCHASE_DEBOUNCE = d
				end
				if okC and type(c) == "number" then
					PURCHASE_COOLDOWN = c
				end
				return
			end
		end
	end
end

local function initNetworking()
	if AuctioneerNet then
		return true
	end
	tryLoadFlagsFromMemory()
	AuctioneerNet = findAuctioneerViaUpvalues()
	if not AuctioneerNet then
		AuctioneerNet = findAuctioneerNetInMemory()
	end
	if AuctioneerNet then
		findBuyLotFunction()
		return true
	end
	return false
end

local function getAuctionScrollingFrame()
	local auction = PlayerGui:FindFirstChild("Auction")
	if auction then
		local frame = auction:FindFirstChild("Frame")
		if frame then
			local scrolling = frame:FindFirstChild("ScrollingFrame")
			if scrolling then
				return scrolling
			end
		end
	end
	for _, gui in ipairs(PlayerGui:GetChildren()) do
		if gui:IsA("ScreenGui") and gui:FindFirstChild("Frame", true) then
			for _, desc in ipairs(gui:GetDescendants()) do
				if desc:IsA("ScrollingFrame") then
					for _, child in ipairs(desc:GetChildren()) do
						if child:IsA("GuiObject") and child.Name:sub(1, 4) == "Lot_" then
							return desc
						end
					end
				end
			end
		end
	end
	return nil
end

local function getAuctionGui()
	local scrolling = getAuctionScrollingFrame()
	if not scrolling then
		return nil
	end
	return scrolling:FindFirstAncestorOfClass("ScreenGui"), scrolling
end

local function lotIdFromFrameName(name)
	if typeof(name) ~= "string" then
		return nil
	end
	if name:sub(1, 4) == "Lot_" then
		return name:sub(5)
	end
	return nil
end

local function isLotFrame(obj)
	if not obj or not obj:IsA("GuiObject") then
		return false
	end
	return lotIdFromFrameName(obj.Name) ~= nil
end

local function getMainFrame(lotFrame)
	if not lotFrame then
		return nil
	end
	local direct = lotFrame:FindFirstChild("Main_Frame")
if not direct then
	for _, v in ipairs(lotFrame:GetDescendants()) do
		if v.Name == "Main_Frame" then
			direct = v
			break
		end
	end
end
	if direct then
		return direct
	end
	local inner = lotFrame:FindFirstChild("Frame")
	if inner then
		return inner:FindFirstChild("Main_Frame")
	end
	return nil
end

local function readLabelText(guiObject)
	if not guiObject then
		return ""
	end
	if (guiObject:IsA("TextLabel") or guiObject:IsA("TextButton")) and guiObject.Text ~= "" then
		return guiObject.Text
	end
	for _, child in ipairs(guiObject:GetDescendants()) do
		if (child:IsA("TextLabel") or child:IsA("TextButton")) and child.Text ~= "" then
			return child.Text
		end
	end
	return ""
end

local function isGuiLotAvailable(mainFrame)
	if not mainFrame then
		return false
	end
	local oos = mainFrame:FindFirstChild("OUT_OF_STOCK")
	if oos and oos:IsA("GuiObject") and oos.Visible then
		return false
	end
	local exp = mainFrame:FindFirstChild("EXPIRED")
	if exp and exp:IsA("GuiObject") and exp.Visible then
		return false
	end
	local buy = mainFrame:FindFirstChild("BuyButton")
	if buy and buy:IsA("GuiButton") then
		if not buy.Visible or not buy.Active then
			return false
		end
		if buy.BackgroundTransparency >= 0.5 then
			return false
		end
	end
	return true
end

local function trim(s)
	if typeof(s) ~= "string" then
		return ""
	end
	return (s:match("^%s*(.-)%s*$"))
end

local function readBuyPrice(buyButton)
	if not buyButton then
		return "", 0
	end
	local textObj = buyButton:FindFirstChild("Text")
	local priceText = readLabelText(textObj or buyButton)
	if priceText == "" then
		priceText = readLabelText(buyButton)
	end
	return priceText, parsePrice(priceText)
end

local function readItemName(mainFrame)
	if not mainFrame then
		return ""
	end
	local itemNameObj = mainFrame:FindFirstChild("ItemName")
	local name = trim(readLabelText(itemNameObj))
	if name ~= "" then
		return name
	end
	local imageDisplay = mainFrame:FindFirstChild("ImageDisplay") or mainFrame
	local tip = imageDisplay:GetAttribute("ItemToolTip")
	if typeof(tip) == "string" and tip ~= "" then
		return trim(tip)
	end
	return ""
end

local function parseGuiLotFrame(lotFrame)
	local lotId = lotIdFromFrameName(lotFrame.Name)
	local mainFrame = getMainFrame(lotFrame)
	if not lotId or not mainFrame then
		return nil
	end
	local buyButton = mainFrame:FindFirstChild("BuyButton")
	local priceText, price = readBuyPrice(buyButton)
	return {
		lotId = lotId,
		lotFrame = lotFrame,
		mainFrame = mainFrame,
		itemName = readItemName(mainFrame),
		price = price,
		priceText = priceText,
		buyButton = buyButton,
		available = isGuiLotAvailable(mainFrame),
	}
end

local function scanGuiLots()
	local scrolling = getAuctionScrollingFrame()
	if not scrolling then
		guiLotCount = 0
		return {}
	end
	local results = {}
	local seen = {}
	for _, child in ipairs(scrolling:GetChildren()) do
		if isLotFrame(child) then
			local guiLot = parseGuiLotFrame(child)
			if guiLot and not seen[guiLot.lotId] then
				seen[guiLot.lotId] = true
				table.insert(results, guiLot)
			end
		end
	end
	if #results == 0 then
		for _, desc in ipairs(scrolling:GetDescendants()) do
			if isLotFrame(desc) and not seen[lotIdFromFrameName(desc.Name)] then
				local guiLot = parseGuiLotFrame(desc)
				if guiLot then
					seen[guiLot.lotId] = true
					table.insert(results, guiLot)
				end
			end
		end
	end
	guiLotCount = #results
	return results
end

local function nameMatches(displayName, query)
	if query == "" or displayName == "" then
		return false
	end
	local q = normalizeName(query)
	local n = normalizeName(displayName)
	if n == q then
		return true
	end
	if n:find(q, 1, true) ~= nil then
		return true
	end
	if q:find(n, 1, true) ~= nil then
		return true
	end
	return false
end

local function canPurchaseLot(lotId)
	local clock = os.clock()
	if purchaseDebounce[lotId] and clock - purchaseDebounce[lotId] < PURCHASE_DEBOUNCE then
		return false
	end
	if clock < (purchaseCooldownUntil[lotId] or 0) then
		return false
	end
	return true
end

local function isLotDataTable(t)
	if type(t) ~= "table" then
		return false
	end
	if typeof(rawget(t, "lotId")) ~= "string" then
		return false
	end
	if type(rawget(t, "startPrice")) ~= "number" then
		return false
	end
	if type(rawget(t, "rolledAt")) ~= "number" then
		return false
	end
	return true
end

local function findLotDataInMemory(lotId)
	if typeof(getgc_fn) ~= "function" or lotId == "" then
		return nil
	end
	for _, obj in getgc_fn(true) do
		if isLotDataTable(obj) and rawget(obj, "lotId") == lotId then
			return obj
		end
	end
	return nil
end

local function findLotData(lotId)
	for i = 1, #lots do
		if lots[i].lotId == lotId then
			return lots[i]
		end
	end
	return findLotDataInMemory(lotId)
end

local function getWatchlistMatch(displayName)
	for i = 1, #watchlist do
		local entry = watchlist[i]
		if nameMatches(displayName, entry.name) then
			return entry
		end
	end
	return nil
end

local function resolvePurchasePrice(lot, guiLot)
	local now = serverNow()
	if lot then
		return Auctioneer.CurrentPrice(lot, now)
	end
	if guiLot then
		if guiLot.price > 0 then
			return guiLot.price
		end
		return parsePrice(guiLot.priceText)
	end
	return 0
end

local function syncLotsFromMemory()
	if #lots > 0 then
		return
	end
	if typeof(getgc_fn) ~= "function" then
		return
	end
	for _, obj in getgc_fn(true) do
		if type(obj) == "table" and #obj >= 1 and #obj <= 30 then
			local allLots = true
			for i = 1, #obj do
				if not isLotDataTable(obj[i]) then
					allLots = false
					break
				end
			end
			if allLots then
				lots = {}
				for i = 1, #obj do
					table.insert(lots, obj[i])
				end
				return
			end
		end
	end
end

local function buyLotDirect(lotData)
	if not lotData or not isLotDataTable(lotData) then
		return false
	end
	local fn = findBuyLotFunction()
	if not fn then
		return false
	end
	if not canPurchaseLot(lotData.lotId) then
		return false
	end
	local ok, err = pcall(fn, lotData)
	if not ok then
		statusMessage = "buyLot call failed: " .. tostring(err)
		return false
	end
	statusMessage = "Buying " .. Auctioneer.DisplayName(lotData) .. " (direct)"
	return true
end

local function buyLotRemote(lot, price)
	local lotId = lot.lotId
	if not canPurchaseLot(lotId) then
		return false
	end
	if not AuctioneerNet or not AuctioneerNet.PurchaseLot then
		return false
	end
	local clock = os.clock()
	purchaseDebounce[lotId] = clock
	local ok, err = pcall(function()
		AuctioneerNet.PurchaseLot:Fire(lotId, price)
	end)
	if not ok then
		purchaseDebounce[lotId] = nil
		statusMessage = "Packet buy failed: " .. tostring(err)
		return false
	end
	if PURCHASE_COOLDOWN > 0 then
		purchaseCooldownUntil[lotId] = clock + PURCHASE_COOLDOWN
	end
	local label = Auctioneer.DisplayName(lot)
	if label == "" then
		label = lotId
	end
	statusMessage = "Buying " .. label .. " @ " .. formatPrice(price)
	return true
end

local function buyGuiLot(guiLot)
	if not guiLot or not canPurchaseLot(guiLot.lotId) or not isGuiLotAvailable(guiLot.mainFrame) then
		return false
	end
	syncLotsFromMemory()
	local lotData = findLotData(guiLot.lotId)
	local price = resolvePurchasePrice(lotData, guiLot)
	if price <= 0 then
		statusMessage = "Could not read price for " .. guiLot.itemName
		return false
	end
	local entry = getWatchlistMatch(guiLot.itemName)
	if entry and price > entry.maxPrice then
		return false
	end
	if lotData and buyLotDirect(lotData) then
		return true
	end
	if AuctioneerNet then
		local lotForRemote = lotData or { lotId = guiLot.lotId, item = guiLot.itemName }
		return buyLotRemote(lotForRemote, price)
	end
	return buyViaGui(guiLot)
end

buyViaGui = function(guiLot)
	if not guiLot or not canPurchaseLot(guiLot.lotId) or not isGuiLotAvailable(guiLot.mainFrame) then
		return false
	end
	local clock = os.clock()
	purchaseDebounce[guiLot.lotId] = clock
	local ok, err = pcall(function()
		if not fireGuiButton(guiLot.buyButton) then
			error("BuyButton fire failed")
		end
	end)
	if not ok then
		purchaseDebounce[guiLot.lotId] = nil
		statusMessage = "GUI buy failed: " .. tostring(err)
		return false
	end
	if PURCHASE_COOLDOWN > 0 then
		purchaseCooldownUntil[guiLot.lotId] = clock + PURCHASE_COOLDOWN
	end
	statusMessage = "Buying " .. guiLot.itemName .. " @ " .. guiLot.priceText .. " (UI)"
	return true
end

local function applySnapshot(payload)
	if typeof(payload) ~= "table" then
		return
	end
	lots = {}
	local manifest = payload.manifest
	if typeof(manifest) == "table" and typeof(manifest.lots) == "table" then
		for _, lot in pairs(manifest.lots) do
			if typeof(lot) == "table" and typeof(lot.lotId) == "string" then
				table.insert(lots, lot)
			end
		end
	end
	if typeof(payload.stock) == "table" then
		stock = payload.stock
	end
end

local function applyStockUpdate(payload)
	if typeof(payload) == "table" and typeof(payload.stock) == "table" then
		stock = payload.stock
	end
end

local function findWatchlistEntryIndex(name)
	local n = normalizeName(name)
	for i = 1, #watchlist do
		if normalizeName(watchlist[i].name) == n then
			return i
		end
	end
	return nil
end

local function addWatchlistItem(name, maxPrice)
	name = name:match("^%s*(.-)%s*$")
	if name == "" or maxPrice <= 0 then
		statusMessage = "Enter item name and max price first"
		return false
	end
	local existing = findWatchlistEntryIndex(name)
	if existing then
		watchlist[existing].maxPrice = maxPrice
		statusMessage = "Updated " .. name .. " <= " .. formatPrice(maxPrice)
	else
		table.insert(watchlist, { name = name, maxPrice = maxPrice })
		statusMessage = "Added " .. name .. " <= " .. formatPrice(maxPrice)
	end
	return true
end

local function removeWatchlistItem(index)
	if watchlist[index] then
		local removed = watchlist[index].name
		table.remove(watchlist, index)
		statusMessage = "Removed " .. removed
	end
end

local function isLotPurchasable(lot, now)
	local remaining = stock[lot.lotId]
	if not Auctioneer.IsActive(lot, now, remaining) then
		return false
	end
	if lot.stockQuantity ~= nil and remaining ~= nil and remaining <= 0 then
		return false
	end
	return lot.expiresAt > now
end

local function findBestSnapshotLot()
	local now = serverNow()
	local bestLot = nil
	local bestPrice = math.huge
	local bestEntry = nil
	for _, lot in ipairs(lots) do
		if isLotPurchasable(lot, now) then
			local entry = getWatchlistMatch(lot.item or "")
			if not entry then
				entry = getWatchlistMatch(Auctioneer.DisplayName(lot))
			end
			if entry then
				local price = Auctioneer.CurrentPrice(lot, now)
				if price <= entry.maxPrice and price < bestPrice then
					bestLot = lot
					bestPrice = price
					bestEntry = entry
				end
			end
		end
	end
	return bestLot, bestPrice, bestEntry
end

local function findBestGuiLot()
	local best = nil
	local bestPrice = math.huge
	local bestEntry = nil
	for _, guiLot in ipairs(scanGuiLots()) do
		if guiLot.available and guiLot.itemName ~= "" then
			local entry = getWatchlistMatch(guiLot.itemName)
			if entry then
				local lotData = findLotData(guiLot.lotId)
				local price = resolvePurchasePrice(lotData, guiLot)
				if price > 0 and price <= entry.maxPrice and price < bestPrice then
					best = guiLot
					best.price = price
					if lotData then
						best.lotData = lotData
					end
					bestPrice = price
					bestEntry = entry
				end
			end
		end
	end
	return best, bestPrice, bestEntry
end

local lastAutoBuyTick = 0
local AUTO_BUY_INTERVAL = 0.2

local function tickAutoBuy()
	if not enabled or #watchlist == 0 then
		return
	end
	local clock = os.clock()
	if clock - lastAutoBuyTick < AUTO_BUY_INTERVAL then
		return
	end
	lastAutoBuyTick = clock
	if not AuctioneerNet then
		initNetworking()
		if AuctioneerNet then
			bindNetworkingEvents()
			requestSnapshotOnce()
		end
	end
	syncLotsFromMemory()
	local lot, price, entry = findBestSnapshotLot()
	lastMatchedLot = lot
	lastMatchedGuiLot = nil
	lastMatchedEntry = entry
	if lot and price then
		buyLotRemote(lot, price)
		return
	end
	local guiLot, _, guiEntry = findBestGuiLot()
	lastMatchedGuiLot = guiLot
	lastMatchedEntry = guiEntry
	if guiLot then
		if not buyGuiLot(guiLot) and guiLot.buyButton then
			buyViaGui(guiLot)
		end
		return
	end
	local hint = ""
	if guiLotCount > 0 and #watchlist > 0 then
		local sample = scanGuiLots()[1]
		if sample then
			hint = " | e.g. UI: " .. sample.itemName .. " @ " .. sample.priceText
		end
	end
	statusMessage = "Watching " .. tostring(#watchlist) .. " items (" .. tostring(guiLotCount) .. " UI lots)" .. hint
end

bindNetworkingEvents = function()
	if eventsBound or not AuctioneerNet then
		return
	end
	eventsBound = true
	if AuctioneerNet.Snapshot and AuctioneerNet.Snapshot.OnClientEvent then
		AuctioneerNet.Snapshot.OnClientEvent:Connect(applySnapshot)
	end
	if AuctioneerNet.StockUpdate and AuctioneerNet.StockUpdate.OnClientEvent then
		AuctioneerNet.StockUpdate.OnClientEvent:Connect(applyStockUpdate)
	end
	if AuctioneerNet.PurchaseResult and AuctioneerNet.PurchaseResult.OnClientEvent then
		AuctioneerNet.PurchaseResult.OnClientEvent:Connect(function(lotId, success)
			purchaseDebounce[lotId] = nil
			if success then
				statusMessage = "Purchased " .. tostring(lotId) .. "!"
			else
				statusMessage = "Rejected " .. tostring(lotId)
				purchaseCooldownUntil[lotId] = nil
			end
		end)
	end
end

requestSnapshotOnce = function()
	if not AuctioneerNet or not AuctioneerNet.RequestSnapshot then
		return
	end
	local ok, result = pcall(function()
		return AuctioneerNet.RequestSnapshot:Fire()
	end)
	if ok and result then
		applySnapshot(result)
	end
end

