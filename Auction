local function fireGuiButton(button)
	if not button or not button:IsA("GuiButton") then
		return false
	end
	if not button.Visible or not button.Active then
		return false
	end

	local fired = false
	local function runConnection(conn)
		if type(conn) ~= "table" then
			return
		end
		if type(conn.Function) == "function" then
			local ok = pcall(conn.Function)
			if ok then
				fired = true
			end
		end
		if type(conn.Fire) == "function" then
			local ok1 = pcall(function()
				conn:Fire()
			end)
			if ok1 then
				fired = true
			end
			local ok2 = pcall(conn.Fire, conn)
			if ok2 then
				fired = true
			end
		end
	end

	if typeof(getconnections_fn) == "function" then
		local signals = { button.Activated, button.MouseButton1Click }
		for si = 1, #signals do
			local ok, connections = pcall(getconnections_fn, signals[si])
			if ok and type(connections) == "table" then
				for ci = 1, #connections do
					runConnection(connections[ci])
				end
			end
		end
	end

	if not fired and typeof(firesignal_fn) == "function" then
		pcall(firesignal_fn, button.Activated)
		pcall(firesignal_fn, button.MouseButton1Click)
		fired = true
	end

	if not fired then
		local ok = pcall(function()
			button:Activate()
		end)
		if ok then
			fired = true
		end
	end

	return fired
end

local Auctioneer = {}
function Auctioneer.CurrentPrice(lot, now)
	if lot.decrementIntervalSeconds <= 0 then
		return lot.startPrice
	end
	local elapsed = now - lot.rolledAt
	if elapsed < 0 then
		elapsed = 0
	end
	local ticks = math.floor(elapsed / lot.decrementIntervalSeconds)
	local decrement = math.floor((lot.startPrice * lot.decrementPercent / 100) + 0.5)
local price = lot.startPrice - decrement * ticks
	if price < lot.minPrice then
		price = lot.minPrice
	end
	return price
end
function Auctioneer.IsActive(lot, now, remainingStock)
	if lot.expiresAt <= now then
		return false
	end
	if remainingStock == nil then
		return true
	end
	return remainingStock > 0
end
function Auctioneer.DisplayName(lot)
	if lot.displayName and lot.displayName ~= "" then
		return lot.displayName
	end
	local parts = {}
	local fields = { lot.type, lot.size, lot.mutation, lot.item }
	for fi = 1, #fields do
		local part = fields[fi]
		if part and part ~= "" then
			table.insert(parts, part)
		end
	end
	return table.concat(parts, " ")
end

