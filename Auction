local function computeUiScale()
	local vp = getViewport()
	local base = 380
	local scale = vp.X / base
	if isMobileLayout() then
		scale = math.min(vp.X / 360, vp.Y / 680)
	end
	return math.clamp(scale, 0.72, 1.15)
end

