task.spawn(function()
	while ScreenGui.Parent do
		scanGuiLots()
		CountLabel.Text = "Watchlist: " .. tostring(#watchlist) .. " | Snapshot: " .. tostring(#lots) .. " | UI: " .. tostring(guiLotCount) .. " | Net: " .. tostring(AuctioneerNet ~= nil) .. " | buyLot: " .. tostring(buyLotFn ~= nil)
		StatusLabel.Text = "Status: " .. statusMessage
		if lastMatchedEntry then
			local targetText = formatPrice(lastMatchedEntry.maxPrice)
			if lastMatchedLot then
				local p = Auctioneer.CurrentPrice(lastMatchedLot, serverNow())
				LiveLabel.Text = "Live: " .. Auctioneer.DisplayName(lastMatchedLot) .. " @ " .. formatPrice(p) .. " (max " .. targetText .. ")"
			elseif lastMatchedGuiLot then
				LiveLabel.Text = "Live (UI): " .. lastMatchedGuiLot.itemName .. " @ " .. lastMatchedGuiLot.priceText .. " (max " .. targetText .. ")"
			else
				LiveLabel.Text = "Live: watching " .. lastMatchedEntry.name
			end
		else
			LiveLabel.Text = "Live: no matching lot"
		end
		if not uiExpanded then
			SubTitle.Text = (#watchlist > 0 and (tostring(#watchlist) .. " items") or "Collapsed") .. (enabled and " | ON" or " | OFF")
		end
		task.wait(0.25)
	end
end)

