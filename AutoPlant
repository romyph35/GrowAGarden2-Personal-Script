local function isSprinklerFolderName(name)
	for _, folderName in SPRINKLER_FOLDERS do
		if name == folderName then
			return true
		end
	end
	return false
end

local function shuffleList(list)
	for i = #list, 2, -1 do
		local j = math.random(1, i)
		list[i], list[j] = list[j], list[i]
	end
end

local function takeRandomSpot()
	if #spotQueue == 0 then
		return nil
	end
	local idx = math.random(1, #spotQueue)
	return table.remove(spotQueue, idx)
end

