end

local function getPlayerPlot()
	local plotId = LocalPlayer:GetAttribute("PlotId")
	if not plotId then return nil end
	return Gardens:FindFirstChild("Plot" .. tostring(plotId))
end

local function getInstancePosition(inst)
	if inst:IsA("BasePart") then return inst.Position end
	if inst:IsA("Attachment") then return inst.WorldPosition end
	if inst:IsA("Model") or inst:IsA("Folder") then
		local root = inst:FindFirstChild("Root")
		if root and root:IsA("BasePart") then return root.Position end
		if inst.PrimaryPart then return inst.PrimaryPart.Position end
		local part = inst:FindFirstChild("Part")
		if part and part:IsA("BasePart") then return part.Position end
		part = inst:FindFirstChildWhichIsA("BasePart", true)
		if part then return part.Position end
	end
	return nil
end

local function normalizeText(text)
	return string.lower(string.gsub(tostring(text), "[%s_%-]", ""))
end

local function isSuperSprinklerName(text)
	return normalizeText(text) == normalizeText(TARGET_SPRINKLER)
end

local function getSprinklerName(inst)
	local value = inst:GetAttribute(SPRINKLER_ATTR)
	if value then return value end
	for _, desc in inst:GetDescendants() do
		value = desc:GetAttribute(SPRINKLER_ATTR)
		if value then return value end
	end
	return nil
end

local function getSprinklerFolders(plot)
	if not plot then return {} end
	local folders = {}
	for _, folderName in SPRINKLER_FOLDERS do
		local folder = plot:FindFirstChild(folderName)
		if folder then
			table.insert(folders, folder)
		end
	end
	return folders
end

local function findSuperSprinkler(plot)
	for _, folder in getSprinklerFolders(plot) do
		for _, sprinklerInst in folder:GetChildren() do
			local sprinklerName = getSprinklerName(sprinklerInst)
			if sprinklerName and isSuperSprinklerName(sprinklerName) then
				local pos = getInstancePosition(sprinklerInst)
				if pos then
					return pos, tostring(sprinklerName), sprinklerInst
				end
			end
		end
	end
	return nil, nil, nil
end

local function clearSprinklerWatchers()
	for _, conn in sprinklerWatchers do
		conn:Disconnect()
	end
	table.clear(sprinklerWatchers)
end

local function onSprinklerChanged()
	if not userEnabled then return end

	local plot = getPlayerPlot()
	local pos, name, inst = findSuperSprinkler(plot)
	if pos then
		if trackedSprinkler ~= inst then
			trackedSprinkler = inst
			plantedCount = 0
			rebuildSpotQueue()
		else
			rebuildSpotQueue()
		end
	else
		trackedSprinkler = nil
		table.clear(spotQueue)
	end
end

local function hookSprinklerInstance(inst)
	table.insert(sprinklerWatchers, inst:GetAttributeChangedSignal(SPRINKLER_ATTR):Connect(onSprinklerChanged))
	table.insert(sprinklerWatchers, inst.AncestryChanged:Connect(onSprinklerChanged))
	task.defer(onSprinklerChanged)
end

local function watchSprinklerFolder(plot)
	clearSprinklerWatchers()
	if not plot then return end

	local folders = getSprinklerFolders(plot)
	if #folders == 0 then
		table.insert(sprinklerWatchers, plot.ChildAdded:Connect(function(child)
			if isSprinklerFolderName(child.Name) then
				watchSprinklerFolder(plot)
				onSprinklerChanged()
			end
		end))
		return
	end

	for _, folder in folders do
		table.insert(sprinklerWatchers, folder.ChildAdded:Connect(function(child)
			hookSprinklerInstance(child)
			onSprinklerChanged()
		end))
		table.insert(sprinklerWatchers, folder.ChildRemoved:Connect(onSprinklerChanged))
		for _, child in folder:GetChildren() do
			hookSprinklerInstance(child)
		end
	end
end

local function getEquippedTool()
	local character = LocalPlayer.Character
	if not character then return nil end
	return character:FindFirstChildWhichIsA("Tool")
end

local function findCarrotSeedTool()
	local function scan(container)
		if not container then return nil end
		for _, child in container:GetChildren() do
			if child:IsA("Tool") then
				local seedType = child:GetAttribute("SeedTool")
				local lowerName = string.lower(child.Name)
				if seedType then
					local s = string.lower(tostring(seedType))
					if s == string.lower(SEED_NAME) or string.find(lowerName, string.lower(SEED_NAME), 1, true) then
						return child, seedType
					end
				elseif string.find(lowerName, string.lower(SEED_NAME), 1, true) then
					return child, SEED_NAME
				end
			end
		end
		return nil
	end

	local equipped = getEquippedTool()
	if equipped then
		local seedType = equipped:GetAttribute("SeedTool")
		if seedType and string.lower(tostring(seedType)) == string.lower(SEED_NAME) then
			return equipped, seedType
		end
		if string.find(string.lower(equipped.Name), string.lower(SEED_NAME), 1, true) then
			return equipped, seedType or SEED_NAME
		end
	end

	local fromChar = scan(LocalPlayer.Character)
	if fromChar then return fromChar end
	return scan(LocalPlayer:FindFirstChildOfClass("Backpack"))
end

local function equipSeedTool(tool)
	if not tool then return false end
	if getEquippedTool() == tool then return true end
	local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return false end
	humanoid:EquipTool(tool)
	return true
end

local function getOccupiedXZ(plot)
	local occupied = {}
	local plants = plot:FindFirstChild("Plants")
	if not plants then return occupied end
	for _, plant in plants:GetChildren() do
		local pos
		if plant:IsA("Model") then
			local part = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart", true)
			if part then pos = part.Position end
		elseif plant:IsA("BasePart") then
			pos = plant.Position
		end
		if pos then table.insert(occupied, Vector2.new(pos.X, pos.Z)) end
	end
	return occupied
end

local function isSpotFree(position, occupied)
	local test = Vector2.new(position.X, position.Z)
	for _, occ in occupied do
		if (test - occ).Magnitude < MIN_PLANT_GAP then return false end
	end
	return true
end

local function getPlantAreas(plot)
	local areas = {}
	for _, part in CollectionService:GetTagged("PlantArea") do
		if part:IsDescendantOf(plot) then
			table.insert(areas, part)
		end
	end
	if #areas == 0 then
		for _, inst in plot:GetDescendants() do
			if inst:IsA("BasePart") then
				local n = string.lower(inst.Name)
				if n == "plantarea" or n == "dirt" or n == "soil" or n == "farm" or n == "plot" then
					table.insert(areas, inst)
				end
			end
		end
	end
	return areas
end

local function createPlantAreaParams(areas)
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Include
	params.FilterDescendantsInstances = areas
	return params
end

local function createPlantsParams()
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Include
	local folders = {}
	for _, plot in Gardens:GetChildren() do
		local plants = plot:FindFirstChild("Plants")
		if plants then table.insert(folders, plants) end
	end
	params.FilterDescendantsInstances = folders
	return params
end

local function raycastPlantPosition(origin, plantAreaParams, plantsParams, plot)
	local hit = workspace:Raycast(origin, Vector3.new(0, -500, 0), plantAreaParams)
	if not hit or not hit.Instance:IsDescendantOf(plot) then return nil end
	local plantHit = workspace:Raycast(origin, Vector3.new(0, -500, 0), plantsParams)
	if plantHit then
		local a = Vector2.new(hit.Position.X, hit.Position.Z)
		local p = Vector2.new(plantHit.Position.X, plantHit.Position.Z)
		if (p - a).Magnitude < MIN_PLANT_GAP then return nil end
	end
	return hit.Position
end

rebuildSpotQueue = function()
	spotQueue = {}

	local plot = getPlayerPlot()
	if not plot then
		anchorLabel = "none"
		return 0
	end

	local anchorPos, anchorName, sprinklerInst = findSuperSprinkler(plot)
	if not anchorPos then
		anchorLabel = "none"
		trackedSprinkler = nil
		return 0
	end

	trackedSprinkler = sprinklerInst
	anchorLabel = anchorName

	local areas = getPlantAreas(plot)
	if #areas == 0 then
		return 0
	end

	local plantAreaParams = createPlantAreaParams(areas)
	local plantsParams = createPlantsParams()
	local occupied = getOccupiedXZ(plot)
	local anchorXZ = Vector2.new(anchorPos.X, anchorPos.Z)
	local candidates = {}

	for _, area in areas do
		local size = area.Size
		local cf = area.CFrame
		local halfX = size.X * 0.5
		local halfZ = size.Z * 0.5
		for x = -halfX + GRID_STEP * 0.5, halfX, GRID_STEP do
			for z = -halfZ + GRID_STEP * 0.5, halfZ, GRID_STEP do
				local sample = (cf * CFrame.new(x, size.Y * 0.5 + 8, z)).Position
				local sampleXZ = Vector2.new(sample.X, sample.Z)
				if (sampleXZ - anchorXZ).Magnitude <= plantRadius then
					local plantPos = raycastPlantPosition(sample, plantAreaParams, plantsParams, plot)
					if plantPos and isSpotFree(plantPos, occupied) then
						table.insert(candidates, {
							position = plantPos,
							distance = (sampleXZ - anchorXZ).Magnitude,
						})
					end
				end
			end
		end
	end

	for _, item in candidates do
		table.insert(spotQueue, item.position)
	end
	shuffleList(spotQueue)

	return #spotQueue
end

local function tryPlantAt(position, seedType, tool)
	local now = os.clock()
	if now - lastPlantClock < plantDelay then
		return false
	end

	local planted = false

	if PlantController and PlantController.TryPlantWithRay then
		local origin = position + Vector3.new(0, 30, 0)
		local direction = Vector3.new(0, -60, 0)
		planted = PlantController:TryPlantWithRay(Ray.new(origin, direction)) == true
	else
		Networking.Plant.PlantSeed:Fire(position, seedType, tool)
		planted = true
	end

	if planted then
		lastPlantClock = now
		plantedCount = plantedCount + 1
	end

	return planted
end

local function plantTick()
	if not userEnabled then return end

	local plot = getPlayerPlot()
	if not plot then
		return
	end

	local sprinklerPos, sprinklerName, sprinklerInst = findSuperSprinkler(plot)
	if not sprinklerPos then
		trackedSprinkler = nil
		table.clear(spotQueue)
		return
	end

	if trackedSprinkler ~= sprinklerInst then
		trackedSprinkler = sprinklerInst
		plantedCount = 0
		rebuildSpotQueue()
	end

	local tool, seedType = findCarrotSeedTool()
	if not tool or not seedType then
		return
	end

	equipSeedTool(tool)
	tool = getEquippedTool() or tool

	if #spotQueue == 0 then
		rebuildSpotQueue()
		if #spotQueue == 0 then return end
	end

	local position = takeRandomSpot()
	if position then
		tryPlantAt(position, seedType, tool)
	end
end

