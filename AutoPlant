local function parseNumber(text, fallback, minValue, maxValue)
	local n = tonumber(text)
	if not n then return fallback end
	if minValue and n < minValue then n = minValue end
	if maxValue and n > maxValue then n = maxValue end
	return n
end

local function applySettings()
	plantDelay = parseNumber(speedBox.Text, DEFAULT_DELAY, 0.01, 1)
	plantRadius = parseNumber(radiusBox.Text, DEFAULT_RADIUS, 4, 60)
	speedLabel.Text = string.format("Speed: %.2fs", plantDelay)
	radiusLabel.Text = string.format("Radius: %d studs", math.floor(plantRadius + 0.5))
end

local function onCloseClick()
	userEnabled = false
	refreshToggleUi()
	setVisible(false)
end

local function onToggleClick()
	applySettings()
	userEnabled = not userEnabled
	if userEnabled then
		plantedCount = 0
		watchSprinklerFolder(getPlayerPlot())
		onSprinklerChanged()
	else
		table.clear(spotQueue)
		trackedSprinkler = nil
	end
	refreshToggleUi()
end

local function onRescanClick()
	applySettings()
	rebuildSpotQueue()
end

