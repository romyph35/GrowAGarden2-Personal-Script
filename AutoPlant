floatingToggle.Position = UDim2.new(1, -70, 0, 20)
floatingToggle.BackgroundColor3 = C.accent
floatingToggle.TextScaled = true
floatingToggle.Text = "◆"
floatingToggle.Font = Enum.Font.GothamBold
floatingToggle.TextColor3 = C.text
floatingToggle.Parent = screenGui
floatingToggle.Active = true
floatingToggle.Selectable = true
corner(floatingToggle, 8)
stroke(floatingToggle, C.stroke)

local function setVisible(state)
	main.Visible = state
end

floatingToggle.MouseButton1Click:Connect(function()
	setVisible(not main.Visible)
end)

RunService.Heartbeat:Connect(function()
	if userEnabled then plantTick() end
end)

LocalPlayer:GetAttributeChangedSignal("PlotId"):Connect(function()
	watchSprinklerFolder(getPlayerPlot())
	if userEnabled then onSprinklerChanged() end
end)

-- Desktop keyboard shortcut (RightShift) - doesn't interfere on mobile
pcall(function()
	UserInputService.InputBegan:Connect(function(input, processed)
		if processed then return end
		if input.KeyCode == Enum.KeyCode.RightShift then
			setVisible(not main.Visible)
		end
	end)
end)

applySettings()
watchSprinklerFolder(getPlayerPlot())
rebuildSpotQueue()
setVisible(true)

print("[GardenHub Auto Plant] Loaded. RightShift = toggle.")
