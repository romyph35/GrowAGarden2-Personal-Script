        -- Plant
        PlantStatus    = "Idle",
        PlantsPlanted  = 0,
        PlantSprinkler = "none",
        PlantSpots     = 0,
        -- Sprinkler placement
        SprinklerStatus   = "—",
        SprinklersPlaced  = 0,
        -- Shovel
        ShovelStatus   = "Idle",
        PlantsDetected = 0,
