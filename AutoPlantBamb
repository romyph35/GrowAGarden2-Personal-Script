    local function setStatus(msg) State.SystemStatus = msg end

    -- ══════════════════════════════════════════════════════════════
    -- UTILITY
    -- ══════════════════════════════════════════════════════════════
    local function getPlot()
        local id = LocalPlayer:GetAttribute("PlotId")
        if not id then return nil end
        return Gardens:FindFirstChild("Plot" .. tostring(id))
    end

-- Returns the plant's current height in CENTIMETRES (same unit as MaxAge).
-- Age attribute = current height in cm, set continuously by PlantVisualizerController.
-- MaxAge attribute = final height in cm (from SeedData.MaxAge).
-- Falls back to bounding box if neither attr exists yet.
local function getPlantHeight(plant)
    -- Age is the live cm value — this is what the game uses directly
    local age = tonumber(plant:GetAttribute("Age"))
    if age then return age end  -- cm

    -- Bounding box fallback (convert studs → cm, 1 stud ≈ 28 cm)
    local ok, _, sz = pcall(function() return plant:GetBoundingBox() end)
    if ok and sz then return math.floor(sz.Y * 28) end

    return nil
end

-- Convert cm to feet for display
local function cmToFt(cm)
    return cm / 30.48
end

    local function plantHasFruit(plant)
        if plant:GetAttribute("FruitReady") == true then return true end
        local fa = plant:GetAttribute("Fruit")
        if fa ~= nil and fa ~= "" and fa ~= false then return true end
        for _, d in plant:GetDescendants() do
            if CollectionService:HasTag(d, "Fruit") then return true end
            if d:GetAttribute("Fruit")     ~= nil then return true end
            if d:GetAttribute("FruitName") ~= nil then return true end
        end
        return false
    end

    local function unequipAll()
        if not Character then return end
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if not bp then return end
        for _, t in Character:GetChildren() do
            if t:IsA("Tool") then pcall(function() t.Parent = bp end) end
        end
        for _ = 1, 10 do
            task.wait(0.05)
            if not Character:FindFirstChildOfClass("Tool") then break end
        end
        task.wait(0.1)
    end

    local function equipTool(attrKey, attrVal)
        if Character then
            for _, t in Character:GetChildren() do
                if t:IsA("Tool") and t:GetAttribute(attrKey) == attrVal then return t end
            end
        end
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if not bp then return nil end
        for _, t in bp:GetChildren() do
            if t:IsA("Tool") and t:GetAttribute(attrKey) == attrVal then
                local ok = pcall(function() t.Parent = Character end)
                if ok then
                    for _ = 1, 10 do
                        task.wait(0.05)
                        if Character and Character:FindFirstChild(t.Name) then return t end
                    end
                end
                break
            end
        end
        return nil
    end

    -- ══════════════════════════════════════════════════════════════
    -- AUTO PLANT  (grid scatter around Super Sprinkler)
    -- Adapted from GardenHub concept: reads SprinklerName attribute,
    -- builds a shuffled grid of valid PlantArea spots within radius,
    -- then rapid-fires PlantSeed one spot at a time.
    -- ══════════════════════════════════════════════════════════════

    -- ── Sprinkler detection ───────────────────────────────────────
    local function normText(t) return t:lower():gsub("[%s_%-]","") end

    -- Returns position, name-string, instance of the nearest Super Sprinkler
    -- Searches plot descendants broadly: checks Sprinkler attr, SprinklerName attr,
    -- and name match — covers both folder-based and flat placements
    local function findSuperSprinkler(plot)
        if not plot then return nil, nil, nil end
        local target = normText(CFG.TargetSprinkler)
        local best, bestDist, bestPos = nil, math.huge, nil
        local hrp = Character and Character:FindFirstChild("HumanoidRootPart")
        local ref = hrp and hrp.Position or Vector3.new(0,0,0)

        for _, desc in plot:GetDescendants() do
            if desc:IsA("Model") or desc:IsA("BasePart") then
                -- Try all three attribute patterns the game uses
                local name = desc:GetAttribute("Sprinkler")
                          or desc:GetAttribute("SprinklerName")
                          or (desc:IsA("Model") and desc.Name)
                if name and normText(tostring(name)) == target then
                    local pos
                    if desc:IsA("Model") then
                        if desc.PrimaryPart then
                            pos = desc.PrimaryPart.Position
                        else
                            for _, d in desc:GetDescendants() do
                                if d:IsA("BasePart") then pos = d.Position; break end
                            end
                        end
                    else
                        pos = desc.Position
                    end
                    if pos then
                        local dist = (pos - ref).Magnitude
                        if dist < bestDist then
                            bestDist = dist
                            best     = desc
                            bestPos  = pos
                        end
                    end
                end
            end
        end

        if best then
            return bestPos, tostring(best:GetAttribute("Sprinkler")
                                  or best:GetAttribute("SprinklerName")
                                  or best.Name), best
        end
        return nil, nil, nil
    end

    -- ── Auto Place Sprinkler ──────────────────────────────────────
    -- Finds the sprinkler tool in backpack, raycasts a PlantArea ground
    -- position, then fires Networking.Place.PlaceSprinkler.
    local P_lastPlaceAttempt  = 0
    local P_savedSprinklerPos = nil   -- manually saved placement position

    -- Find sprinkler tool in backpack first, then character (backpack is most likely)
    local function findSprinklerTool()
        local target = CFG.SprinklerToolAttr
        -- Backpack first
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if bp then
            for _, t in bp:GetChildren() do
                if t:IsA("Tool") and t:GetAttribute("Sprinkler") == target then
                    return t
                end
            end
        end
        -- Then character
        if Character then
            for _, t in Character:GetChildren() do
                if t:IsA("Tool") and t:GetAttribute("Sprinkler") == target then
                    return t
                end
            end
        end
        return nil
    end

    -- Equip sprinkler by name — mirrors AutoWateringCan's equipSprinklerTool exactly
    local function equipSprinklerTool(sprinklerName)
        -- Already held?
        if Character then
            for _, t in Character:GetChildren() do
                if t:IsA("Tool") and t:GetAttribute("Sprinkler") == sprinklerName then
                    return t
                end
            end
        end
        -- Move from backpack
        local bp = LocalPlayer:FindFirstChild("Backpack")
        if not bp then return nil end
        for _, t in bp:GetChildren() do
            if t:IsA("Tool") and t:GetAttribute("Sprinkler") == sprinklerName then
                local ok = pcall(function() t.Parent = Character end)
                if ok then
                    for _ = 1, 6 do
                        task.wait(0.05)
                        if Character and Character:FindFirstChild(t.Name) then
                            return t
                        end
                    end
                end
                break
            end
        end
        return nil
    end

    -- Raycast a valid PlantArea ground position inside the plot
    local function getPlantAreaPlacePos(plot)
        if not plot then return nil end
        local parts = {}
        for _, d in plot:GetDescendants() do
            if d:IsA("BasePart") and CollectionService:HasTag(d, "PlantArea") then
                table.insert(parts, d)
            end
        end
        if #parts == 0 then return nil end
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Include
        params.FilterDescendantsInstances = parts
        for _, part in ipairs(parts) do
            local origin = part.Position + Vector3.new(0, 50, 0)
            local result = workspace:Raycast(origin, Vector3.new(0, -200, 0), params)
            if result and CollectionService:HasTag(result.Instance, "PlantArea") then
                return result.Position
            end
        end
        return parts[1].Position
    end

    -- Returns true if the sprinkler was fired successfully
    local function placeSprinkler()
        local now = os.clock()
        if now - P_lastPlaceAttempt < CFG.SprinklerPlaceCooldown then return false end
        P_lastPlaceAttempt = now

        if not Networking or not Networking.Place or not Networking.Place.PlaceSprinkler then
            State.SprinklerStatus = "❌ PlaceSprinkler remote not found"
            return false
        end

        local plot = getPlot()
        if not plot then
            State.SprinklerStatus = "❌ No plot"
            return false
        end

        local plotId = tonumber(plot.Name:match("%d+"))
        if not plotId then
            State.SprinklerStatus = "❌ Bad plot ID"
            return false
        end

        local pos = getPlantAreaPlacePos(plot)
        if not pos then
            State.SprinklerStatus = "❌ No PlantArea found"
            return false
        end

        local tool = findSprinklerTool()
        if not tool then
            State.SprinklerStatus = "❌ No '"..CFG.SprinklerToolAttr.."' in backpack"
            return false
        end

        State.SprinklerStatus = "🌀 Placing sprinkler..."
        State.CurrentAction   = "PlacingSprinkler"
        setStatus("🌀 Placing sprinkler...")

        unequipAll()
        task.wait(0.2)

        -- equipSprinklerTool takes the NAME string, matches AutoWateringCan pattern
        local tool = equipSprinklerTool(CFG.SprinklerToolAttr)
        if not tool then
            State.SprinklerStatus = "❌ Could not equip '"..CFG.SprinklerToolAttr.."'"
            State.CurrentAction   = "Idle"
            return false
        end

        -- Wait for server to replicate the equip before firing the remote
        task.wait(0.4)

        -- Confirm tool is still in Character right before firing
        local heldTool = Character and Character:FindFirstChild(tool.Name)
        if not heldTool then
            State.SprinklerStatus = "❌ Tool lost before fire — retry"
            State.CurrentAction   = "Idle"
            return false
        end

        -- Signature: (position, sprinklerName, tool, plotId)
        local ok, err = pcall(function()
            Networking.Place.PlaceSprinkler:Fire(pos, CFG.SprinklerToolAttr, heldTool, plotId)
        end)

        task.wait(0.5)
        unequipAll()
        State.CurrentAction = "Idle"

        if ok then
            State.SprinklersPlaced += 1
            State.SprinklerStatus = "✅ Fired #"..State.SprinklersPlaced.." (check plot)"
            setStatus("✅ PlaceSprinkler fired — watching plot...")
            return true
        else
            warn("[AutoPlace] PlaceSprinkler fire error: "..tostring(err))
            State.SprinklerStatus = "⚠️ Fire error — check console"
            return false
        end
    end

    -- ── PlantArea helpers ─────────────────────────────────────────
    local function getPlantAreas(plot)        local areas = {}
        for _, part in ipairs(CollectionService:GetTagged("PlantArea")) do
            if part:IsDescendantOf(plot) then table.insert(areas, part) end
        end
        if #areas == 0 then
            for _, inst in plot:GetDescendants() do
                if inst:IsA("BasePart") then
                    local n = inst.Name:lower()
                    if n=="plantarea" or n=="dirt" or n=="soil" or n=="farm" or n=="plot" then
                        table.insert(areas, inst)
                    end
                end
            end
        end
        return areas
    end

    local function getOccupiedXZ(plot)
        local occ = {}
        local plants = plot:FindFirstChild("Plants")
        if not plants then return occ end
        for _, plant in plants:GetChildren() do
            local part = plant:IsA("Model") and (plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart",true))
                    or (plant:IsA("BasePart") and plant)
            if part then table.insert(occ, Vector2.new(part.Position.X, part.Position.Z)) end
        end
        return occ
    end

    local function isSpotFree(pos, occupied)
        local v = Vector2.new(pos.X, pos.Z)
        for _, o in ipairs(occupied) do
            if (v-o).Magnitude < CFG.MinPlantGap then return false end
        end
        return true
    end

    local function makePlantsParams()
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Include
        local folders = {}
        for _, plot in Gardens:GetChildren() do
            local p = plot:FindFirstChild("Plants")
            if p then table.insert(folders, p) end
        end
        params.FilterDescendantsInstances = folders
        return params
    end

    -- ── Spot queue ────────────────────────────────────────────────
    local P_spotQueue     = {}  -- Vector3 positions ready to plant
    local P_trackedInst   = nil -- currently tracked sprinkler Instance
    local P_lastTick      = 0

    local function shuffleInPlace(t)
        for i = #t, 2, -1 do
            local j = math.random(1,i); t[i],t[j] = t[j],t[i]
        end
    end

    local function rebuildSpotQueue()
        P_spotQueue = {}
        local plot = getPlot()
        if not plot then State.PlantSprinkler = "none"; return end

        local anchorPos, anchorName, sprInst = findSuperSprinkler(plot)
        if not anchorPos then
            State.PlantSprinkler = "none"
            P_trackedInst = nil
            return
        end
        State.PlantSprinkler = anchorName
        P_trackedInst = sprInst

        local areas = getPlantAreas(plot)
        if #areas == 0 then return end

        local areaParams = RaycastParams.new()
        areaParams.FilterType = Enum.RaycastFilterType.Include
        areaParams.FilterDescendantsInstances = areas
        local plantsParams = makePlantsParams()
        local occupied = getOccupiedXZ(plot)
        local anchorXZ = Vector2.new(anchorPos.X, anchorPos.Z)
        local step     = CFG.PlantGridStep
        local radius   = CFG.PlantRadius

        for _, area in ipairs(areas) do
            local sz = area.Size
            local cf = area.CFrame
            local hx, hz = sz.X*0.5, sz.Z*0.5
            for x = -hx+step*0.5, hx, step do
                for z = -hz+step*0.5, hz, step do
                    local sample = (cf * CFrame.new(x, sz.Y*0.5+8, z)).Position
                    if (Vector2.new(sample.X,sample.Z)-anchorXZ).Magnitude <= radius then
                        -- Raycast onto PlantArea surface
                        local hit = workspace:Raycast(sample, Vector3.new(0,-500,0), areaParams)
                        if hit and hit.Instance:IsDescendantOf(plot) then
                            -- Check no existing plant is too close
                            local plantHit = workspace:Raycast(sample, Vector3.new(0,-500,0), plantsParams)
                            local plantPos = hit.Position
                            local clear = true
                            if plantHit then
                                local a2 = Vector2.new(plantPos.X,plantPos.Z)
                                local p2 = Vector2.new(plantHit.Position.X,plantHit.Position.Z)
                                if (p2-a2).Magnitude < CFG.MinPlantGap then clear = false end
                            end
                            if clear and isSpotFree(plantPos, occupied) then
                                table.insert(P_spotQueue, plantPos)
                            end
                        end
                    end
                end
            end
        end
        shuffleInPlace(P_spotQueue)
        State.PlantSpots = #P_spotQueue
    end

    -- ── Seed tool helpers ─────────────────────────────────────────
    -- Find seed tool by SeedTool attribute — checks Backpack first, then Character
    local function findSeedTool()
        local seedLower = CFG.SeedAttr:lower()
        -- Scan a container for the matching seed tool
        local function scan(c)
            if not c then return nil, nil end
            for _, t in c:GetChildren() do
                if t:IsA("Tool") then
                    local attr = t:GetAttribute("SeedTool")
                    if attr and attr:lower() == seedLower then
                        return t, attr
                    end
                    -- fallback: tool name contains seed name
                    if t.Name:lower():find(seedLower, 1, true) then
                        return t, attr or CFG.SeedAttr
                    end
                end
            end
            return nil, nil
        end
        -- Backpack first (most common location)
        local bp = LocalPlayer:FindFirstChild("Backpack")
        local t, a = scan(bp)
        if t then return t, a end
        -- Then check if already equipped in Character
        return scan(Character)
    end

    -- Equip seed tool: move from Backpack → Character directly,
    -- then confirm it arrived. Falls back to Humanoid:EquipTool.
    local function equipSeedTool(tool)
        if not tool then return nil end
        if not Character then return nil end

        -- Already in Character — nothing to do
        if tool.Parent == Character then return tool end

        -- Move from Backpack to Character directly
        local ok = pcall(function() tool.Parent = Character end)
        if ok then
            -- Wait up to 0.3s for it to confirm
            for _ = 1, 6 do
                task.wait(0.05)
                if tool.Parent == Character then return tool end
            end
        end

        -- Fallback: Humanoid:EquipTool
        local hum = Character:FindFirstChildOfClass("Humanoid")
        if hum then
            pcall(function() hum:EquipTool(tool) end)
            task.wait(0.1)
        end

        return Character:FindFirstChildWhichIsA("Tool")
    end

    -- ── Plant tick (called from Heartbeat) ───────────────────────
    -- Track whether we were just paused due to missing sprinkler
    local P_waitingForSprinkler = false

    local function plantTick()
        if not CFG.PlantEnabled then return end
        if State.CurrentAction ~= "Idle" then return end
        local now = os.clock()
        if now - P_lastTick < CFG.PlantDelay then return end

        local plot = getPlot()
        if not plot then State.PlantStatus = "❌ No plot"; return end

        -- Confirm / refresh sprinkler
        local _, _, sprInst = findSuperSprinkler(plot)
        if not sprInst then
            P_trackedInst = nil
            P_spotQueue   = {}

            -- First tick without sprinkler: unequip seed immediately
            if not P_waitingForSprinkler then
                P_waitingForSprinkler = true
                unequipAll()
                if CFG.AutoPlaceSprinkler then
                    State.PlantStatus = "🌀 Sprinkler gone — placing new one..."
                else
                    State.PlantStatus = "⏸ Sprinkler gone — unequipped, waiting..."
                end
            else
                if CFG.AutoPlaceSprinkler then
                    State.PlantStatus = "🌀 Placing sprinkler..."
                else
                    State.PlantStatus = "⏸ Waiting for sprinkler..."
                end
            end

            -- Auto-place: fire in a separate thread so Heartbeat isn't blocked
            if CFG.AutoPlaceSprinkler and State.CurrentAction == "Idle" then
                task.spawn(function()
                    local placed = placeSprinkler()
                    if placed then
                        -- Wait up to 5s for sprinkler to appear in plot
                        local deadline = os.clock() + 5
                        while os.clock() < deadline do
                            task.wait(0.25)
                            local p = getPlot()
                            if p then
                                local _, _, newInst = findSuperSprinkler(p)
                                if newInst then
                                    P_waitingForSprinkler = false
                                    P_trackedInst = nil  -- force queue rebuild
                                    State.PlantStatus = "✅ Sprinkler placed — resuming"
                                    break
                                end
                            end
                        end
                    end
                end)
            end
            return
        end

        -- Sprinkler is back — clear waiting flag and rebuild queue
        if P_waitingForSprinkler then
            P_waitingForSprinkler = false
            P_trackedInst = nil
            State.PlantStatus = "✅ Sprinkler detected — resuming"
        end

        if sprInst ~= P_trackedInst then
            P_trackedInst = sprInst
            rebuildSpotQueue()
        end

        -- Find seed tool
        local tool, seedAttr = findSeedTool()
        if not tool or not seedAttr then
            State.PlantStatus = "❌ No '"..CFG.SeedAttr.."' seed in backpack"
            return
        end
        -- Equip and get the live Character-held reference
        local equippedTool = equipSeedTool(tool)
        if not equippedTool then
            State.PlantStatus = "❌ Failed to equip '"..CFG.SeedAttr.."'"
            return
        end
        tool = equippedTool

        -- Refill queue if empty
        if #P_spotQueue == 0 then
            rebuildSpotQueue()
            if #P_spotQueue == 0 then
                State.PlantStatus = "✅ Plot full — rescanning..."
                return
            end
        end

        -- Pop a spot and fire
        local idx = math.random(1, #P_spotQueue)
        local pos = table.remove(P_spotQueue, idx)
        State.PlantSpots = #P_spotQueue

        State.CurrentAction = "Planting"
        local ok, err = pcall(function()
            Networking.Plant.PlantSeed:Fire(pos, seedAttr, tool)
        end)
        P_lastTick = now

        if ok then
            State.PlantsPlanted += 1
            State.PlantStatus = string.format("🌱 Planted #%d  (%s)", State.PlantsPlanted, CFG.SeedAttr)
        else
            State.PlantStatus = "⚠️ PlantSeed: "..tostring(err)
        end
        State.CurrentAction = "Idle"
    end

    -- Watch for PlotId changes → rebuild queue
    LocalPlayer:GetAttributeChangedSignal("PlotId"):Connect(function()
        P_trackedInst = nil
        rebuildSpotQueue()
    end)

    -- Initial queue build
    task.defer(rebuildSpotQueue)

    -- ══════════════════════════════════════════════════════════════
    -- ESP  — BillboardGui above each plant
    -- ══════════════════════════════════════════════════════════════

    -- Table mapping plant → its BillboardGui so we can update / remove them
    local espTags = {}   -- [plant] = { bb, nameLbl, hLbl }

    -- Height is now in cm. HeightThreshold is also in cm.
    -- Colour bands: below threshold = red, below 2× = amber, above = green
    local function heightColor(ageCm, threshold)
        if ageCm == nil     then return Color3.fromRGB(140, 140, 160) end
        if ageCm < threshold   then return Color3.fromRGB(239,  68,  68) end
        if ageCm < threshold*2 then return Color3.fromRGB(255, 180,  55) end
        return Color3.fromRGB(52, 211, 153)
    end

    -- Build one BillboardGui — TEXT ONLY, no background frame.
    -- Two stroked TextLabels stacked: seed name (white) + height (colour-coded).
    -- Stroke gives the black outline that makes text pop against any background.
    local function createESPTag(plant)
        if espTags[plant] then return end

        local adornee = plant.PrimaryPart
        if not adornee then
            for _, d in plant:GetDescendants() do
                if d:IsA("BasePart") then adornee = d; break end
            end
        end
        if not adornee then return end

