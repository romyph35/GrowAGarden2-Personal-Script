    local function removeESPTag(plant)
        local tag = espTags[plant]
        if tag then
            pcall(function() tag.bb:Destroy() end)
            espTags[plant] = nil
        end
    end

    local function updateESPTag(plant)
        local tag = espTags[plant]
        if not tag then return end

        local ageCm  = getPlantHeight(plant)   -- current cm (= Age attr)
        local maxCm  = tonumber(plant:GetAttribute("MaxAge"))
        local hasFruit = plantHasFruit(plant)
        local col    = heightColor(ageCm, CFG.HeightThreshold)

        -- Display as feet: "12.3 / 73.3 ft"
        local hText
        if ageCm and maxCm and maxCm > 0 then
            local curFt = cmToFt(ageCm)
            local maxFt = cmToFt(maxCm)
            hText = string.format("%.1f / %.1f ft", curFt, maxFt)
        elseif ageCm then
            hText = string.format("%.1f ft", cmToFt(ageCm))
        else
            hText = "— ft"
        end

        if hasFruit then hText = hText .. " 🍎" end
        tag.hLbl.Text       = hText
        tag.hLbl.TextColor3 = col

        -- Seed name refresh
        tag.nameLbl.Text = plant:GetAttribute("SeedName") or plant.Name
    end

    -- Scan gardens and create/remove ESP tags as needed
    local function refreshESP()
        if not CFG.ESPEnabled then
            -- Remove all tags
            for plant in pairs(espTags) do removeESPTag(plant) end
            return
        end

        local plotsToScan = {}
        if CFG.ESPAllGardens then
            for _, plot in Gardens:GetChildren() do
                table.insert(plotsToScan, plot)
            end
        else
            local plot = getPlot()
            if plot then table.insert(plotsToScan, plot) end
        end

        -- Build a set of all current valid plants
        local livePlants = {}
        for _, plot in ipairs(plotsToScan) do
            local folder = plot:FindFirstChild("Plants")
            if folder then
                for _, plant in folder:GetChildren() do
                    if plant:IsA("Model") then
                        livePlants[plant] = true
                    end
                end
            end
        end

        -- Create tags for new plants
        for plant in pairs(livePlants) do
            if not espTags[plant] then
                createESPTag(plant)
            end
            updateESPTag(plant)
        end

        -- Remove tags for plants that are gone
        for plant in pairs(espTags) do
            if not livePlants[plant] then
                removeESPTag(plant)
            end
        end
    end

    -- Continuous ESP update loop (runs every 0.5 s)
    task.spawn(function()
        while true do
            task.wait(0.5)
            local ok, err = pcall(refreshESP)
            if not ok then warn("[ESP] " .. tostring(err)) end
        end
    end)

