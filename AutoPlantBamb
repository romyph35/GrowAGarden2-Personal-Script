    -- AUTO SHOVEL
    -- ══════════════════════════════════════════════════════════════
    local function getPlantsToShovel(plot)
        local result = {}
        local folder = plot and plot:FindFirstChild("Plants")
        if not folder then return result end
        for _, plant in folder:GetChildren() do
            if plant:IsA("Model") then
                local h = getPlantHeight(plant)
                if h ~= nil and h < CFG.HeightThreshold and not plantHasFruit(plant) then
                    table.insert(result, plant)
                end
            end
        end
        return result
    end

    local function stopShovel()
        CFG.ShovelEnabled  = false
        State.ShovelStatus = "⏹ Stopped"
        setStatus("⏹ Auto Shovel stopped")
    end

    local lastShovelTick = 0

    RunService.Heartbeat:Connect(function()
        if not CFG.ShovelEnabled then return end
        if State.CurrentAction ~= "Idle" then return end

        local now = os.clock()
        if now - lastShovelTick < CFG.ShovelDelay then return end

        local plot = getPlot()
        if not plot then
            State.ShovelStatus  = "❌ No plot found"
            State.PlantsDetected = 0
            return
        end

        -- Update detected count (all plants, not just shovelable)
        local folder = plot:FindFirstChild("Plants")
        State.PlantsDetected = folder and #folder:GetChildren() or 0

        local targets = getPlantsToShovel(plot)

        if #targets == 0 then
            -- Check if any are being held back because of fruit
            local skipped = 0
            if folder then
                for _, plant in folder:GetChildren() do
                    if plant:IsA("Model") then
                        local h = getPlantHeight(plant)
                        if h ~= nil and h < CFG.HeightThreshold and plantHasFruit(plant) then
                            skipped += 1
                        end
                    end
                end
            end
            if skipped > 0 then
                State.ShovelStatus = "🍎 " .. skipped .. " skipped (has fruit)"
            else
                State.ShovelStatus = "✅ No targets below " .. CFG.HeightThreshold
            end
            return
        end

        -- Claim lock
        State.CurrentAction = "Shoveling"
        lastShovelTick      = now

        unequipAll()

        -- Find shovel tool (boolean or any non-nil Shovel attr)
        local tool = equipTool("Shovel", true)
        if not tool then
            for _, src in {Character, LocalPlayer:FindFirstChild("Backpack")} do
                if src then
                    for _, t in src:GetChildren() do
                        if t:IsA("Tool") and t:GetAttribute("Shovel") ~= nil then
                            tool = t; break
                        end
                    end
                end
                if tool then break end
            end
        end

        if not tool then
            State.ShovelStatus  = "❌ No shovel in backpack"
            setStatus("❌ No shovel available")
            State.CurrentAction = "Idle"
            return
        end

        local plant    = targets[1]
        if not plant or not plant.Parent then
            unequipAll(); State.CurrentAction = "Idle"; return
        end

        local height   = getPlantHeight(plant)
        local plantId  = plant:GetAttribute("PlantId") or plant:GetAttribute("Id") or plant.Name
        local seedName = plant:GetAttribute("SeedName") or "unknown"
        local hStr     = height and tostring(math.floor(height)) or "?"

        State.ShovelStatus = string.format("⛏ %s  h:%s", seedName, hStr)
        setStatus(State.ShovelStatus)

        -- Equip via Humanoid so server sees the tool as held
        local hum = Character and Character:FindFirstChildOfClass("Humanoid")
        if hum then pcall(function() hum:EquipTool(tool) end); task.wait(0.15) end

        -- Re-grab equipped tool reference after equip settle
        local activeTool = (Character and Character:FindFirstChildWhichIsA("Tool")) or tool
        local shovelAttr = activeTool:GetAttribute("Shovel")

        -- Confirmed GAG2 pattern: (id, typeString, toolInstance)
        -- matches PlantSeed: Fire(position, seedType, tool)
        -- and WateringCan:   Fire(position, canType, tool)
        local fired = false
        local ok, err = pcall(function()
            Networking.Shovel.UseShovel:Fire(plantId, shovelAttr, activeTool)
        end)

        if ok then
            fired = true
        else
            warn("[AutoShovel] primary sig failed: "..tostring(err).." — trying id-only")
            -- Fallback: some server versions only need the plantId
            local ok2, err2 = pcall(function()
                Networking.Shovel.UseShovel:Fire(plantId)
            end)
            if ok2 then
                fired = true
            else
                warn("[AutoShovel] fallback also failed: "..tostring(err2))
            end
        end

        if fired then
            State.PlantsShoved += 1
            State.ShovelStatus = string.format("✅ Shoveled %s #%d  h:%s",
                seedName, State.PlantsShoved, hStr)
            setStatus(State.ShovelStatus)
        else
            State.ShovelStatus = "⚠️ Fire failed — check console"
            setStatus(State.ShovelStatus)
        end

        unequipAll()
        State.CurrentAction = "Idle"
    end)

