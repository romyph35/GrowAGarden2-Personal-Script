-- Safe require with retry
local Networking
do
    local ok, result
    for _ = 1, 10 do
        ok, result = pcall(function()
            return require(ReplicatedStorage:WaitForChild("SharedModules", 10):WaitForChild("Networking", 10))
        end)
        if ok and result then Networking = result; break end
        task.wait(1)
    end
    if not Networking then
        warn("[AutoWater] Failed to load Networking module")
        return
    end
end

