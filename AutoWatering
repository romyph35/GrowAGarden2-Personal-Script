-- ════════════════════════════════════════════════════════════
-- UTILITIES
-- ════════════════════════════════════════════════════════════
local function getTargetPlot()
    if STATE.selectedPlotObj and STATE.selectedPlotObj.Parent then
        return STATE.selectedPlotObj
    end
    local plotId = LocalPlayer:GetAttribute("PlotId")
    if not plotId then return nil end
    return Gardens:FindFirstChild("Plot" .. tostring(plotId))
end

local function getPlantPosition(plant)
    if plant:IsA("BasePart") then return plant.Position end
    if plant.PrimaryPart then return plant.PrimaryPart.Position end
    for _, d in plant:GetDescendants() do
        if d:IsA("BasePart") then return d.Position end
    end
    return nil
end

local function getWateringCan()
    if Character then
        for _, item in Character:GetChildren() do
            if item:IsA("Tool") and item:GetAttribute("WateringCan") == "Super Watering Can" then
                return item
            end
        end
    end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, item in backpack:GetChildren() do
            if item:IsA("Tool") and item:GetAttribute("WateringCan") == "Super Watering Can" then
                return item
            end
        end
    end
    return nil
end

local function equipWateringCan()
    if Character then
        for _, item in Character:GetChildren() do
            if item:IsA("Tool") and item:GetAttribute("WateringCan") == "Super Watering Can" then
                return item
            end
        end
    end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return nil end
    for _, item in backpack:GetChildren() do
        if item:IsA("Tool") and item:GetAttribute("WateringCan") == "Super Watering Can" then
            pcall(function() item.Parent = Character end)
            task.wait(0.05)
            if Character and Character:FindFirstChild(item.Name) then return item end
        end
    end
    return nil
end

local function createRaycastParams()
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Include
    local tagged = CollectionService:GetTagged("PlantArea")
    local baseplate = workspace:FindFirstChild("Baseplate")
    if baseplate then table.insert(tagged, baseplate) end
    params.FilterDescendantsInstances = tagged
    return params
end

local function needsWatering(plant)
    return (plant:GetAttribute("WateringLevel") or 0) < 50
end

local function getTargetPlants(plot)
    if not plot then return {} end
    local folder = plot:FindFirstChild("Plants")
    if not folder then return {} end
    local result = {}
    for _, plant in folder:GetChildren() do
        local seed = plant:GetAttribute("SeedName")
        if seed then
            if STATE.selectedSeedName == nil or STATE.selectedSeedName == seed then
                table.insert(result, plant)
            end
        end
    end
    return result
end

local function getSeedNamesInPlot(plot)
    if not plot then return {} end
    local folder = plot:FindFirstChild("Plants")
    if not folder then return {} end
    local seen, names = {}, {}
    for _, plant in folder:GetChildren() do
        local seed = plant:GetAttribute("SeedName")
        if seed and not seen[seed] then
            seen[seed] = true
            table.insert(names, seed)
        end
    end
    table.sort(names)
    return names
end

-- ════════════════════════════════════════════════════════════
-- AUTO TP
-- ════════════════════════════════════════════════════════════
local function teleportToPlant(plant)
    if not CONFIG.autoTP then return end
    if not Character then return end
    local hrp = Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local pos = getPlantPosition(plant)
    if not pos then return end

    -- Place character next to the plant, slightly above ground
    local offset = Vector3.new(CONFIG.tpOffset, 3, 0)
    local targetCF = CFrame.new(pos + offset, pos)

    pcall(function()
        hrp.CFrame = targetCF
    end)
    task.wait(0.1)
end

-- ════════════════════════════════════════════════════════════
-- WATERING
-- ════════════════════════════════════════════════════════════
local function waterPlant(plant)
    if not plant or not plant.Parent then return false end
    if STATE.wateredPlants[plant] then return false end
    if not needsWatering(plant) then return false end

    local now = os.clock()
    if now - STATE.lastWaterTime < CONFIG.waterDelay then return false end

    -- TP to plant first
    teleportToPlant(plant)

    local can = getWateringCan()
    if not can then can = equipWateringCan() end
    if not can then
        STATE.statusMessage = "❌ No Super Watering Can found"
        return false
    end
    local canName = can:GetAttribute("WateringCan")
    if not canName then return false end

    local worldPos = getPlantPosition(plant)
    if not worldPos then return false end

    local params = createRaycastParams()
    local result = workspace:Raycast(
        worldPos + Vector3.new(0,10,0),
        Vector3.new(0,-50,0),
        params
    )

    local hitPos
    if result then
        hitPos = CollectionService:HasTag(result.Instance, "PlantArea")
            and result.Position
            or Vector3.new(worldPos.X, result.Position.Y, worldPos.Z)
    else
        hitPos = Vector3.new(worldPos.X, worldPos.Y - 1, worldPos.Z)
    end

    local ok = pcall(function()
        Networking.WateringCan.UseWateringCan:Fire(
            hitPos - Vector3.new(0, 0.3, 0),
            canName,
            can
        )
    end)

    if ok then
        STATE.wateredPlants[plant] = true
        STATE.lastWaterTime = now
        STATE.plantsWatered += 1
        return true
    end
    return false
end

-- Auto-equip watcher
local lastEquipCheck = 0
RunService.Heartbeat:Connect(function()
    if not CONFIG.enabled then return end
    local now = os.clock()
    if now - lastEquipCheck < 0.5 then return end
    lastEquipCheck = now
    if Character then
        for _, item in Character:GetChildren() do
            if item:IsA("Tool") and item:GetAttribute("WateringCan") == "Super Watering Can" then
                return
            end
        end
    end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return end
    for _, item in backpack:GetChildren() do
        if item:IsA("Tool") and item:GetAttribute("WateringCan") == "Super Watering Can" then
            pcall(function() item.Parent = Character end)
            STATE.statusMessage = "🪣 Auto-equipped Super Watering Can"
            return
        end
    end
    STATE.statusMessage = "❌ No Super Watering Can in backpack"
end)

-- Main water loop
local lastTick = 0
RunService.Heartbeat:Connect(function()
    if not CONFIG.enabled then return end
    local now = os.clock()
    if now - lastTick < CONFIG.checkInterval then return end
    lastTick = now

    local plot = getTargetPlot()
    if not plot then
        STATE.statusMessage = "❌ No plot selected"
        return
    end

    local plants = getTargetPlants(plot)
    STATE.plantsFound = #plants

    if #plants == 0 then
        local f = STATE.selectedSeedName and (" (" .. STATE.selectedSeedName .. ")") or ""
        STATE.statusMessage = "📭 No plants found" .. f
        return
    end

    for _, plant in ipairs(plants) do
        if waterPlant(plant) then
            local seed = plant:GetAttribute("SeedName") or "plant"
            STATE.statusMessage = "💧 Watering " .. seed .. " in " .. plot.Name
            return
        end
    end

    -- Full loop done — restart
    STATE.wateredPlants = {}
    STATE.plantsWatered = 0
    STATE.statusMessage = "🔄 Restarting loop..."
end)

