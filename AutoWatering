local plotButtons = {}
local seedButtons = {}

local function getPlotOwnerDisplay(plot)
    local uid = plot:GetAttribute("OwnerUserId")
    if typeof(uid) == "number" then
        local p = Players:GetPlayerByUserId(uid)
        if p then return p.DisplayName end
    end
    local name = plot:GetAttribute("Owner")
    if typeof(name) == "string" and name ~= "" then return name end
    return nil
end

local function updatePlotHighlights()
    for name, btn in pairs(plotButtons) do
        btn.BackgroundColor3 = (STATE.selectedPlotObj and STATE.selectedPlotObj.Name == name)
            and C.itemSel or C.item
    end
end

local function updateSeedHighlights()
    for key, btn in pairs(seedButtons) do
        local isSel = (key == "" and STATE.selectedSeedName == nil)
                   or (key ~= "" and STATE.selectedSeedName == key)
        btn.BackgroundColor3 = isSel and C.seedSel or C.item
    end
end

local rebuildSeedButtons

rebuildSeedButtons = function()
    for _, child in SeedContent:GetChildren() do
        if child:IsA("TextButton") or (child:IsA("TextLabel") and child.LayoutOrder > 0) then
            child:Destroy()
        end
    end
    table.clear(seedButtons)

    local allBtn = mkRowBtn(SeedContent, 1, function()
        STATE.selectedSeedName = nil
        STATE.wateredPlants = {}; STATE.plantsWatered = 0
        updateSeedHighlights()
        STATE.statusMessage = "🌿 Targeting all plant types"
    end)
    allBtn.BackgroundColor3 = STATE.selectedSeedName == nil and C.seedSel or C.item
    mkLabel({
        text = "🌿  All Plants",
        size = FONT_MD, font = Enum.Font.GothamBold, color = C.green,
        sz = UDim2.new(1,0,1,0), pos = UDim2.new(0,10,0,0),
        parent = allBtn,
    })
    seedButtons[""] = allBtn

    local plot = getTargetPlot()
    local names = getSeedNamesInPlot(plot)

    if #names == 0 then
        local empty = mkLabel({
            text = "  No plants in this plot",
            size = FONT_SM, font = Enum.Font.Gotham, color = C.sub,
            sz = UDim2.new(1,0,0,28), parent = SeedContent,
        })
        empty.LayoutOrder = 2
        return
    end

    for i, seedName in ipairs(names) do
        local cnt = 0
        local pf = plot and plot:FindFirstChild("Plants")
        if pf then
            for _, pl in pf:GetChildren() do
                if pl:GetAttribute("SeedName") == seedName then cnt += 1 end
            end
        end

        local btn = mkRowBtn(SeedContent, i + 1, function()
            STATE.selectedSeedName = seedName
            STATE.wateredPlants = {}; STATE.plantsWatered = 0
            updateSeedHighlights()
            STATE.statusMessage = "🎯 Targeting: " .. seedName
        end)
        btn.BackgroundColor3 = STATE.selectedSeedName == seedName and C.seedSel or C.item

        mkLabel({
            text = "🌸  " .. seedName,
            size = FONT_MD, font = Enum.Font.Gotham, color = C.text,
            sz = UDim2.new(0.72,0,1,0), pos = UDim2.new(0,10,0,0),
            parent = btn,
        })
        mkLabel({
            text = "×" .. cnt,
            size = FONT_SM, font = Enum.Font.Gotham, color = C.sub,
            sz = UDim2.new(0.25,0,1,0), pos = UDim2.new(0.75,0,0,0),
            xalign = Enum.TextXAlignment.Right,
            parent = btn,
        })
        seedButtons[seedName] = btn
    end
end

local function buildPlotButton(plot, order)
    local btn = mkRowBtn(PlotContent, order, function()
        STATE.selectedPlotObj = plot
        STATE.selectedSeedName = nil
        STATE.wateredPlants = {}; STATE.plantsWatered = 0
        updatePlotHighlights()
        rebuildSeedButtons()
        STATE.statusMessage = "🎯 Targeting " .. plot.Name
    end)

    local nameLabel = mkLabel({
        text = "", size = FONT_MD, font = Enum.Font.GothamBold, color = C.text,
        sz = UDim2.new(0.62,0,0.55,0), pos = UDim2.new(0,10,0,4),
        parent = btn,
    })
    local ownerLabel = mkLabel({
        text = "", size = FONT_SM, font = Enum.Font.Gotham, color = C.sub,
        sz = UDim2.new(0.62,0,0.4,0), pos = UDim2.new(0,10,0.58,0),
        parent = btn,
    })
    local cntLabel = mkLabel({
        text = "—", size = FONT_SM, font = Enum.Font.Gotham, color = C.sub,
        sz = UDim2.new(0.34,0,1,0), pos = UDim2.new(0.66,0,0,0),
        xalign = Enum.TextXAlignment.Right,
        parent = btn,
    })
    mkPad(cntLabel, 0, 8)

    local function refresh()
        local myId = LocalPlayer:GetAttribute("PlotId")
        local isMine = myId and plot.Name == ("Plot" .. tostring(myId))
        local owner = getPlotOwnerDisplay(plot)
        local pf = plot:FindFirstChild("Plants")
        local cnt = 0
        if pf then
            for _, p in pf:GetChildren() do
                if p:GetAttribute("SeedName") then cnt += 1 end
            end
        end
        if isMine then
            nameLabel.Text = "🏠 " .. plot.Name
            nameLabel.TextColor3 = C.green
            ownerLabel.Text = "Your plot"
        elseif owner then
            nameLabel.Text = "👤 " .. plot.Name
            nameLabel.TextColor3 = C.text
            ownerLabel.Text = owner
        else
            nameLabel.Text = "🌿 " .. plot.Name
            nameLabel.TextColor3 = C.sub
            ownerLabel.Text = "Empty"
        end
        cntLabel.Text = cnt > 0 and ("🌱 " .. cnt) or "—"
    end

    refresh()
    plot:GetAttributeChangedSignal("Owner"):Connect(refresh)
    plot:GetAttributeChangedSignal("OwnerUserId"):Connect(refresh)
    local pf = plot:FindFirstChild("Plants")
    if pf then
        pf.ChildAdded:Connect(refresh)
        pf.ChildRemoved:Connect(refresh)
    end
    plotButtons[plot.Name] = btn
end

local function populatePlots()
    for _, c in PlotContent:GetChildren() do
        if c:IsA("TextButton") then c:Destroy() end
    end
    table.clear(plotButtons)

    local plots = Gardens:GetChildren()
    table.sort(plots, function(a, b)
        return (tonumber(a.Name:match("%d+")) or 0) < (tonumber(b.Name:match("%d+")) or 0)
    end)
    for i, plot in ipairs(plots) do
        buildPlotButton(plot, i)
    end

    if not (STATE.selectedPlotObj and STATE.selectedPlotObj.Parent) then
        local myId = LocalPlayer:GetAttribute("PlotId")
        if myId then
            local mine = Gardens:FindFirstChild("Plot" .. tostring(myId))
            if mine then STATE.selectedPlotObj = mine end
        end
    end
    updatePlotHighlights()
    rebuildSeedButtons()
end

