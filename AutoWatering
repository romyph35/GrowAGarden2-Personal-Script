task.spawn(function()
    -- Wait for character
    if not LocalPlayer.Character then
        LocalPlayer.CharacterAdded:Wait()
    end

    -- Wait for PlotId (up to 60s)
    local attempts = 0
    while LocalPlayer:GetAttribute("PlotId") == nil and attempts < 120 do
        task.wait(0.5)
        attempts += 1
    end

    -- Wait for Gardens children (up to 60s)
    attempts = 0
    while #Gardens:GetChildren() == 0 and attempts < 120 do
        task.wait(0.5)
        attempts += 1
    end

    -- Extra wait to make sure attributes are replicated
    task.wait(1)

    populatePlots()

    Gardens.ChildAdded:Connect(function(c)
        if c:IsA("Model") or c:IsA("Folder") then populatePlots() end
    end)
    Gardens.ChildRemoved:Connect(function() populatePlots() end)
    LocalPlayer:GetAttributeChangedSignal("PlotId"):Connect(populatePlots)

    STATE.statusMessage = "✅ Ready — select a plot"
end)

