local function mkRowBtn(parent, order, callback)
    local btn = Instance.new("TextButton")
    btn.LayoutOrder = order
    btn.Size = UDim2.new(1,0,0,ROW_H)
    btn.BackgroundColor3 = C.item
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false
    btn.Text = ""
    btn.Parent = parent
    mkCorner(btn, 6)
    btn.MouseButton1Click:Connect(callback)
    btn.TouchTap:Connect(callback)
    btn.MouseEnter:Connect(function()
        if btn.BackgroundColor3 ~= C.itemSel and btn.BackgroundColor3 ~= C.seedSel then
            btn.BackgroundColor3 = C.itemHov
        end
    end)
    btn.MouseLeave:Connect(function()
        if btn.BackgroundColor3 == C.itemHov then btn.BackgroundColor3 = C.item end
    end)
    return btn
end

