local function mkSection(order, title, defaultOpen)
    local wrapper = Instance.new("Frame")
    wrapper.LayoutOrder = order
    wrapper.Size = UDim2.new(1,0,0,0)
    wrapper.AutomaticSize = Enum.AutomaticSize.Y
    wrapper.BackgroundTransparency = 1
    wrapper.BorderSizePixel = 0
    wrapper.Parent = Body
    local wLayout = Instance.new("UIListLayout")
    wLayout.Padding = UDim.new(0,4)
    wLayout.SortOrder = Enum.SortOrder.LayoutOrder
    wLayout.Parent = wrapper

    local hdr = Instance.new("TextButton")
    hdr.LayoutOrder = 0
    hdr.Size = UDim2.new(1,0,0,ROW_H-4)
    hdr.BackgroundColor3 = C.section
    hdr.BorderSizePixel = 0
    hdr.AutoButtonColor = false
    hdr.Text = ""
    hdr.Parent = wrapper
    mkCorner(hdr, 6)
    mkLabel({
        text = title, size = FONT_MD, font = Enum.Font.GothamBold, color = C.text,
        sz = UDim2.new(1,-40,1,0), pos = UDim2.new(0,10,0,0), z=1, parent = hdr,
    })
    local arrow = mkLabel({
        text = defaultOpen ~= false and "▾" or "▸",
        size = FONT_MD+2, font = Enum.Font.GothamBold, color = C.sub,
        sz = UDim2.new(0,28,1,0), pos = UDim2.new(1,-32,0,0),
        xalign = Enum.TextXAlignment.Center, z=1, parent = hdr,
    })

    local content = Instance.new("Frame")
    content.LayoutOrder = 1
    content.Size = UDim2.new(1,0,0,0)
    content.AutomaticSize = Enum.AutomaticSize.Y
    content.BackgroundColor3 = C.bg
    content.BorderSizePixel = 0
    content.Visible = defaultOpen ~= false
    content.Parent = wrapper
    mkCorner(content, 6)
    local cLayout = Instance.new("UIListLayout")
    cLayout.Padding = UDim.new(0,4)
    cLayout.SortOrder = Enum.SortOrder.LayoutOrder
    cLayout.Parent = content
    mkPad(content, 6,6,6,6)

    local open = defaultOpen ~= false
    local function toggle()
        open = not open
        content.Visible = open
        arrow.Text = open and "▾" or "▸"
    end
    hdr.MouseButton1Click:Connect(toggle)
    hdr.TouchTap:Connect(toggle)
    hdr.MouseEnter:Connect(function() hdr.BackgroundColor3 = C.itemHov end)
    hdr.MouseLeave:Connect(function() hdr.BackgroundColor3 = C.section end)
    return content
end

