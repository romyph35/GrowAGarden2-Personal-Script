local function rebuildCart()
    for _,c in cartScroll:GetChildren() do if c:IsA("Frame") then c:Destroy() end end
    local n=#cart
    cartHdr.Text=("Cart  %d / %d"):format(n,MAX_CART)
    cartHdr.TextColor3=n>=MAX_CART and C.red or C.text
    cartEmpty.Visible=n==0
    for i,entry in ipairs(cart) do
        local row=Instance.new("Frame"); row.BackgroundColor3=C.field
        row.Size=UDim2.new(1,0,0,BTN_H-4); row.BorderSizePixel=0; row.Parent=cartScroll; mkCorner(row,5)
        mkLabel(row,{Text=entry.label, Size=UDim2.new(1,-34,1,0), Position=UDim2.fromOffset(7,0),
            TextColor3=C.text, TextSize=FS_SM, TextTruncate=Enum.TextTruncate.AtEnd})
        local xb=mkBtn(row,{Size=UDim2.fromOffset(22,18), Position=UDim2.new(1,-26,0.5,-9),
            BackgroundColor3=C.red, Text="x", TextSize=FS_SM})
        local idx=i
        local function rem()
            table.remove(cart,idx); rebuildCart(); setStatus("Removed.",false)
        end
        xb.MouseButton1Click:Connect(rem); xb.TouchTap:Connect(rem)
    end
end

-- add single
local function doAddOne()
    refreshFruits()
    if not selectedFruit then setStatus("No fruit selected.",true); return end
    if not selectedFruit.id then setStatus("Fruit has no Id.",true); return end
    if #cart>=MAX_CART then setStatus("Cart full ("..MAX_CART..").",true); return end
    for _,e in cart do
        if e.id==selectedFruit.id then setStatus("Already in cart.",true); return end
    end
    table.insert(cart,{id=selectedFruit.id, label=selectedFruit.label, itemKey=selectedFruit.itemKey})
    rebuildCart(); setStatus("Added: "..selectedFruit.label,false)
end
addOneBtn.MouseButton1Click:Connect(doAddOne)

-- add all
local addAllBtn=mkBtn(sendPanel,{Size=UDim2.new(1,0,0,BTN_H),
    Text="Add All Fruits (up to "..MAX_CART..")",
    BackgroundColor3=C.panel, TextColor3=C.text, TextSize=FS_SM, LayoutOrder=6})
mkStroke(addAllBtn,C.stroke)
local function doAddAll()
    refreshFruits(); local added=0
    for _,f in currentFruits do
        if #cart>=MAX_CART then break end
        if f.id then
            local dup=false
            for _,e in cart do if e.id==f.id then dup=true; break end end
            if not dup then table.insert(cart,{id=f.id,label=f.label,itemKey=f.itemKey}); added+=1 end
        end
    end
    rebuildCart(); setStatus(added>0 and ("Added %d fruits"):format(added) or "Nothing new.",added==0)
end
addAllBtn.MouseButton1Click:Connect(doAddAll); addAllBtn.TouchTap:Connect(doAddAll)

