local function mkCorner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6); c.Parent = p; return c
end
local function mkStroke(p, col, t)
    local s = Instance.new("UIStroke")
    s.Color = col or C.stroke; s.Thickness = t or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; s.Parent = p; return s
end
local function mkPad(p, t, r, b, l)
    local v = Instance.new("UIPadding")
    v.PaddingTop    = UDim.new(0, t or PAD)
    v.PaddingRight  = UDim.new(0, r or PAD)
    v.PaddingBottom = UDim.new(0, b or PAD)
    v.PaddingLeft   = UDim.new(0, l or PAD)
    v.Parent = p; return v
end
local function mkLabel(parent, props)
    local l = Instance.new("TextLabel"); l.BackgroundTransparency = 1
    l.Font = Enum.Font.GothamMedium; l.TextSize = FS_MD; l.TextColor3 = C.muted
    l.TextXAlignment = Enum.TextXAlignment.Left
    for k, v in props do l[k] = v end; l.Parent = parent; return l
end
local function mkBox(parent, props)
    local t = Instance.new("TextBox"); t.BackgroundColor3 = C.field
    t.TextColor3 = C.text; t.PlaceholderColor3 = C.muted
    t.Font = Enum.Font.Gotham; t.TextSize = FS_MD
    t.ClearTextOnFocus = false; t.Text = ""
    for k, v in props do t[k] = v end
    mkCorner(t, 6); mkStroke(t); t.Parent = parent; return t
end
local function mkBtn(parent, props)
    local b = Instance.new("TextButton"); b.AutoButtonColor = true
    b.BackgroundColor3 = C.accent; b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold; b.TextSize = FS_MD; b.Text = "Button"
    for k, v in props do b[k] = v end
    mkCorner(b, 6); b.Parent = parent; return b
end
