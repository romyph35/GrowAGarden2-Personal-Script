local function clearRecip()
    resolvedId,resolvedName=nil,nil
    avImg.Image=""; avPH.Visible=true
    recInfo.Text="No recipient set"; recInfo.TextColor3=C.muted
end
local function resolveRecip()
    if lookupBusy then return false end
    local raw=recBox.Text:gsub("^%s*@?",""):gsub("%s+$","")
    if raw=="" then clearRecip(); setStatus("Enter a username or UserId.",true); return false end
    local num=tonumber(raw)
    if num and num>0 then
        resolvedId=num; resolvedName="User"..num; setAvatar(num)
        recInfo.Text=("@%s  (ID: %d)"):format(resolvedName,num)
        recInfo.TextColor3=C.text; setStatus("Recipient set.",false); return true
    end
    if #raw<3 or #raw>20 or not raw:match("^[%w_]+$") then
        setStatus("Invalid username.",true); return false
    end
    lookupBusy=true; setRecBtn.Text="..."; setRecBtn.BackgroundColor3=C.aDark
    local ok,uid,dn=pcall(function() return Networking.Mailbox.LookupPlayer:Fire(raw) end)
    lookupBusy=false; setRecBtn.Text="Set"; setRecBtn.BackgroundColor3=C.accent
    if not ok or type(uid)~="number" or uid<=0 then
        clearRecip(); setStatus("Player not found.",true); return false
    end
    resolvedId=uid; resolvedName=(dn~="" and dn) or raw; setAvatar(uid)
    recInfo.Text=("@%s  (ID: %d)"):format(resolvedName,uid)
    recInfo.TextColor3=C.text; setStatus("Recipient set.",false); return true
end
setRecBtn.MouseButton1Click:Connect(resolveRecip)
