        local k = f.itemKey
        if k and not seen[k] then seen[k]=true; table.insert(types,k) end
    end
    table.sort(types)
    return types
end

local function setFilterType(t)
    filterType = t
    typeBtn.Text = t and t or "All Types"
    typeBtn.TextColor3 = t and C.accent or C.text
    -- update addAll label (addAllBtn defined below, safe to reference at call time)
