local minimized=false; local savedSize=root.Size
local function doMinimize()
    minimized=not minimized
    if minimized then
        savedSize=root.Size; closeDropdown()
        TweenService:Create(root,TweenInfo.new(0.15),
            {Size=UDim2.fromOffset(WIN_W, HDR_H+TAB_H)}):Play()
        sendPanel.Visible=false; histPanel.Visible=false
    else
        sendPanel.Visible=true; histPanel.Visible=false
        TweenService:Create(root,TweenInfo.new(0.15),{Size=savedSize}):Play()
    end
end
minBtn.MouseButton1Click:Connect(doMinimize); minBtn.TouchTap:Connect(doMinimize)
