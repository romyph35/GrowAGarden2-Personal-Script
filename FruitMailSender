-- ════════════════════════════════════════════════════════════
-- FRUIT SCANNER
-- ════════════════════════════════════════════════════════════
local function getFruits()
    local list, seen = {}, {}
    local function scan(c)
        if not c then return end
        for _, item in c:GetChildren() do
            local fn = item:GetAttribute("Fruit")
            if fn and not seen[item] then
                seen[item] = true
                local mut = item:GetAttribute("Mutation")
                local wt  = item:GetAttribute("Weight")
                local id  = item:GetAttribute("Id")
                local lbl = fn
                if mut and mut ~= "" then lbl = mut.." "..fn end
                if wt then lbl = lbl..string.format(" (%.1fg)", wt) end
                table.insert(list, {id=id, label=lbl, itemKey=fn, mutation=mut, weight=wt})
            end
        end
    end
    scan(LocalPlayer.Character)
    scan(LocalPlayer:FindFirstChild("Backpack"))
    table.sort(list, function(a,b) return a.label:lower() < b.label:lower() end)
    return list
end

