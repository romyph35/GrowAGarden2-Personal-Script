local sendBtn=mkBtn(sendPanel,{Size=UDim2.new(1,0,0,math.max(BTN_H+6,36)),
    Text="Send All (auto-batched)", BackgroundColor3=C.orange,
    TextSize=FS_LG, LayoutOrder=8})

local sending=false
local function doSend()
    if sending then return end
    if not resolvedId then if not resolveRecip() then return end end
    if #cart==0 then setStatus("Cart is empty.",true); return end
    local snapshot={}; for _,e in ipairs(cart) do table.insert(snapshot,e) end
    local total=#snapshot
    local chunks={}
    for i=1,total,SERVER_CHUNK do
        local chunk={}
        for j=i,math.min(i+SERVER_CHUNK-1,total) do
            table.insert(chunk,{Category="HarvestedFruits",ItemKey=snapshot[j].id,Count=1})
        end
        table.insert(chunks,chunk)
    end
    sending=true; sendBtn.Text="Sending..."; sendBtn.BackgroundColor3=C.aDark; sendBtn.Active=false
    task.spawn(function()
        local sent=0; local failed=false
        for i,chunk in ipairs(chunks) do
            if i>1 then
                for cd=BATCH_DELAY,1,-1 do
                    if not sending then break end
                    setStatus(("Batch %d/%d — next in %ds"):format(i,#chunks,cd),false)
                    task.wait(1)
                end
            end
            if not sending then setStatus(("Stopped. Sent %d/%d"):format(sent,total),true); break end
            setStatus(("Batch %d/%d · %d fruits"):format(i,#chunks,#chunk),false)
            local ok,success,msg=pcall(function()
                return Networking.Mailbox.SendBatch:Fire(resolvedId,chunk,"")
            end)
            if ok and success then
                sent=sent+#chunk
                setStatus(("Batch %d/%d done · %d/%d"):format(i,#chunks,sent,total),false)
            else
                local reason=(not ok and "Remote error")
                    or (type(msg)=="string" and msg~="" and msg) or "Send failed"
                setStatus(("Batch %d failed: %s  (%d/%d sent)"):format(i,reason,sent,total),true)
                failed=true; break
            end
        end
        sending=false; sendBtn.Active=true
        sendBtn.Text="Send All (auto-batched)"; sendBtn.BackgroundColor3=C.orange
        if sent>0 then
            local sentLabels={}
            for i=1,sent do table.insert(sentLabels,snapshot[i].label) end
            addHistory(resolvedName,resolvedId,sentLabels,sent)
            sendWebhook(resolvedName,resolvedId,sentLabels,sent)
            for _=1,sent do table.remove(cart,1) end
            rebuildCart()
        end
        if not failed then
            setStatus(("Done! Sent %d fruit(s) to @%s"):format(sent,resolvedName or "?"),false)
        end
        refreshFruits()
    end)
end
sendBtn.MouseButton1Click:Connect(doSend); sendBtn.TouchTap:Connect(doSend)

