    if selectedFruit then
        local found=false
        for _,f in currentFruits do if f.id==selectedFruit.id then selectedFruit=f; found=true; break end end
        if not found then selectedFruit=currentFruits[1] end
    else selectedFruit=currentFruits[1] end
