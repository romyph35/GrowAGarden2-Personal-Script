local function tableToString(tbl)
    if typeof(tbl) ~= "table" then return tostring(tbl) end
    return table.concat(tbl, ", ")
end

local function parseInput(oldValue, text)
    if typeof(oldValue) == "boolean" then
        return text:lower() == "true"
    elseif typeof(oldValue) == "number" then
        return tonumber(text) or oldValue
    elseif typeof(oldValue) == "table" then
        if text == "" then
            return {}
        end
        local split = string.split(text, ",")
        for i,v in ipairs(split) do
            split[i] = v:gsub("^%s*(.-)%s*$", "%1")
        end
        return split
    else
        return text
    end
end

