--[[
    Plant & Sprinkler Performance
    All buttons are one-click. Each auto-applies to newly spawned instances too.

    Buttons:
      1. Destroy Plant Meshes     — numbered BaseParts (direct children of plant)
      2. Remove Swirl + Emitter   — Swirl/Emitter objects inside Fruits descendants
      3. Reduce Orb Particles     — arcana_orbSource_03_crimson rate/size cut
      4. Remove Sprinkler Effects — Attachments inside Root of each sprinkler model
]]

local Players          = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer      = Players.LocalPlayer
local PlayerGui        = LocalPlayer:WaitForChild("PlayerGui")
local Gardens          = workspace:WaitForChild("Gardens")

-- ════════════════════════════════════════════════════════════
-- CLEANUP FUNCTIONS
-- ════════════════════════════════════════════════════════════

-- 1. Destroy numbered BaseParts (direct children of plant model only)
local meshDone = false
local function cleanMeshesInPlant(plant)
    for _, part in ipairs(plant:GetChildren()) do
        if part:IsA("BasePart") and tonumber(part.Name) then
            part:Destroy()
        end
    end
end
local function destroyAllMeshes()
    meshDone = true
    local n = 0
    for _, plot in Gardens:GetChildren() do
        local pf = plot:FindFirstChild("Plants")
        if pf then
            for _, plant in pf:GetChildren() do
                cleanMeshesInPlant(plant); n += 1
            end
        end
    end
    return n
end

-- 2. Destroy Swirl + Emitter anywhere in plant descendants (inside Fruits etc.)
local swirlDone = false
local function cleanSwirlInPlant(plant)
    for _, desc in ipairs(plant:GetDescendants()) do
        if desc.Name == "Swirl" or desc.Name == "Emitter" then
            pcall(function() desc:Destroy() end)
        end
    end
end
local function destroyAllSwirl()
    swirlDone = true
    local n = 0
    for _, plot in Gardens:GetChildren() do
        local pf = plot:FindFirstChild("Plants")
        if pf then
            for _, plant in pf:GetChildren() do
                for _, desc in ipairs(plant:GetDescendants()) do
                    if desc.Name == "Swirl" or desc.Name == "Emitter" then
                        pcall(function() desc:Destroy() end)
                        n += 1
                    end
                end
            end
        end
    end
    return n
end

-- 3. Destroy arcana_orbSource_03_crimson ParticleEmitters entirely
local orbDone = false
local function cleanOrbInPlant(plant)
    for _, desc in ipairs(plant:GetDescendants()) do
        if desc:IsA("ParticleEmitter")
            and desc.Name == "arcana_orbSource_03_crimson" then
            pcall(function() desc:Destroy() end)
        end
    end
end
local function destroyAllOrbs()
    orbDone = true
    local n = 0
    for _, plot in Gardens:GetChildren() do
        local pf = plot:FindFirstChild("Plants")
        if pf then
            for _, plant in pf:GetChildren() do
                for _, desc in ipairs(plant:GetDescendants()) do
                    if desc:IsA("ParticleEmitter")
                        and desc.Name == "arcana_orbSource_03_crimson" then
                        pcall(function() desc:Destroy() end)
                        n += 1
                    end
                end
            end
        end
    end
    return n
end

-- 4. Remove Attachments inside Root of each sprinkler model
--    Structure: Plot# > Sprinklers > [sprinkler] > Root > Attachment
local attachDone = false
local function cleanAttachInSprinkler(sprinkler)
    local root = sprinkler:FindFirstChild("Root")
    if root then
        for _, child in ipairs(root:GetChildren()) do
            if child:IsA("Attachment") then
                child:Destroy()
            end
        end
    end
end
local function removeAllSprinklerAttachments()
    attachDone = true
    local n = 0
    for _, plot in Gardens:GetChildren() do
        local sf = plot:FindFirstChild("Sprinklers")
        if sf then
            for _, sprinkler in sf:GetChildren() do
                local root = sprinkler:FindFirstChild("Root")
                if root then
                    for _, child in ipairs(root:GetChildren()) do
                        if child:IsA("Attachment") then
                            child:Destroy(); n += 1
                        end
                    end
                end
            end
        end
    end
    return n
end

-- ════════════════════════════════════════════════════════════
-- AUTO-APPLY to newly spawned plants & sprinklers
-- ════════════════════════════════════════════════════════════
task.spawn(function()
    local function watchPlot(plot)
        -- Plants
        local pf = plot:FindFirstChild("Plants")
        if not pf then pf = plot:WaitForChild("Plants", 10) end
        if pf then
            pf.ChildAdded:Connect(function(plant)
                task.wait(0.5)
                if meshDone  then cleanMeshesInPlant(plant) end
                if swirlDone then cleanSwirlInPlant(plant) end
                if orbDone   then cleanOrbInPlant(plant) end
            end)
        end
        -- Sprinklers
        local sf = plot:FindFirstChild("Sprinklers")
        if not sf then sf = plot:WaitForChild("Sprinklers", 10) end
        if sf then
            sf.ChildAdded:Connect(function(sprinkler)
                task.wait(0.5)
                if attachDone then cleanAttachInSprinkler(sprinkler) end
            end)
        end
    end
    for _, plot in Gardens:GetChildren() do watchPlot(plot) end
    Gardens.ChildAdded:Connect(watchPlot)
end)

