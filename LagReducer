-- Button helper
local function mkBtn(order, label, col, hov, action)
    local btn = Instance.new("TextButton")
    btn.LayoutOrder = order; btn.Size = UDim2.new(1,0,0,BH)
    btn.BackgroundColor3 = col; btn.Text = label
    btn.TextColor3 = C.text; btn.Font = Enum.Font.GothamBold
    btn.TextSize = FS; btn.BorderSizePixel = 0; btn.Parent = body
    do local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,7); c.Parent=btn end
    btn.MouseEnter:Connect(function()
        if btn.Active ~= false then btn.BackgroundColor3 = hov end
    end)
    btn.MouseLeave:Connect(function()
        if btn.Active ~= false then btn.BackgroundColor3 = col end
    end)
    local function fire()
        btn.Text = "Working..."; btn.BackgroundColor3 = C.muted
        btn.Active = false; btn.AutoButtonColor = false
        task.spawn(function()
            local n = action()
            btn.Text = ("✅ Done (%d)"):format(n)
            btn.BackgroundColor3 = C.green
        end)
    end
    btn.MouseButton1Click:Connect(fire)
    -- touch-safe: only fire if finger didn't move
    do
        local ts = nil
        btn.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Touch then ts=i.Position end
        end)
        btn.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Touch and ts then
                if (i.Position-ts).Magnitude < 15 and btn.Active ~= false then fire() end
                ts = nil
            end
        end)
    end
    return btn
end

mkBtn(2, "⚡ Destroy Plant Meshes",         C.purple, C.pHov,  destroyAllMeshes)
mkBtn(3, "🌀 Remove Swirl + Emitter",        C.blue,   C.bHov,  destroyAllSwirl)
mkBtn(4, "✨ Destroy Orb Particles",          C.orange, C.oHov,  destroyAllOrbs)
mkBtn(5, "💧 Remove Sprinkler Attachments",  C.teal,   C.tHov,  removeAllSprinklerAttachments)

-- ════════════════════════════════════════════════════════════
-- DRAG (converts to offset on first drag — stable on all devices)
-- ════════════════════════════════════════════════════════════
do
    local dragging, dragStart, startXY = false, nil, nil
    local cam = workspace.CurrentCamera

    titleBar.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1
        or i.UserInputType==Enum.UserInputType.Touch then
            dragging = true
            dragStart = Vector2.new(i.Position.X, i.Position.Y)
            local ap = win.AbsolutePosition
            startXY = Vector2.new(ap.X, ap.Y)
            win.AnchorPoint = Vector2.new(0,0)
            win.Position = UDim2.fromOffset(ap.X, ap.Y)
        end
    end)
    titleBar.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1
        or i.UserInputType==Enum.UserInputType.Touch then dragging=false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType~=Enum.UserInputType.MouseMovement
        and i.UserInputType~=Enum.UserInputType.Touch then return end
        local d = Vector2.new(i.Position.X, i.Position.Y) - dragStart
        local sv = cam.ViewportSize; local ws = win.AbsoluteSize
        win.Position = UDim2.fromOffset(
            math.clamp(startXY.X+d.X, 0, sv.X-ws.X),
            math.clamp(startXY.Y+d.Y, 0, sv.Y-ws.Y))
    end)
end

print("[PlantPerformance] Ready — 4 one-click buttons")
