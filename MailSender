local selectedCategory, sending, minimized = "Seeds", false, false
local savedSize = root.Size

local function cartTotals()
	local entries, total = 0, 0
	for _, entry in cart do entries += 1 total += entry.count end
	return entries, total
end

local function refreshCartUI()
	local entries, total = cartTotals()
	cartLabel.Text = string.format("Cart · %d entries · %d total", entries, total)
	for _, child in cartFrame:GetChildren() do
		if child:IsA("GuiObject") and not child:IsA("UIListLayout") and not child:IsA("UIPadding") then child:Destroy() end
	end
	for cartKey, entry in cart do
		local row = Instance.new("Frame")
		row.BackgroundColor3 = C.field
		row.Size = UDim2.new(1, 0, 0, 30)
		row.Parent = cartFrame
		corner(row, 6)
		makeLabel(row, { Text = string.format("%s  x%s", entry.label, entry.count), Size = UDim2.new(1, -34, 1, 0), Position = UDim2.fromOffset(8, 0), TextColor3 = C.text, TextTruncate = Enum.TextTruncate.AtEnd })
		local remove = makeButton(row, { Size = UDim2.fromOffset(24, 24), Position = UDim2.new(1, -28, 0.5, -12), Text = "x", BackgroundColor3 = C.panel, TextSize = 16 })
		remove.MouseButton1Click:Connect(function() cart[cartKey] = nil refreshCartUI() end)
	end
end

local function refreshItems()
	currentItems = scanCategory(getInventory() or {}, selectedCategory)
	local options = {}
	if #currentItems == 0 then
		itemDropdown.setOptions({})
		itemDropdown.setText("No items")
		selectedItem = nil
		countBox.Text = "0"
		return
	end
	for _, item in currentItems do table.insert(options, { label = item.label, data = item }) end
	itemDropdown.setOptions(options)
	itemDropdown.setText(options[1].label)
	selectedItem = options[1].data
	local maxCount = selectedItem.amount
	if selectedItem.category == "HarvestedFruits" or selectedItem.category == "Pets" then maxCount = 1 end
	countBox.Text = tostring(math.min(maxCount, MAX_PER_LINE))
end

local function refreshCategories()
	local options = {}
	for _, cat in GIFT_CATEGORIES do
		if isGiftableCategory(cat) then
			table.insert(options, { label = if cat == "HarvestedFruits" then "Fruits" else cat, data = cat })
		end
	end
	categoryDropdown.setOptions(options)
	if #options > 0 then categoryDropdown.setText(options[1].label) selectedCategory = options[1].data end
end

categoryDropdown.onChanged(function(opt) selectedCategory = opt.data refreshItems() end)
itemDropdown.onChanged(function(opt)
	selectedItem = opt.data
	if not selectedItem then return end
	local maxCount = selectedItem.amount
	if selectedItem.category == "HarvestedFruits" or selectedItem.category == "Pets" then maxCount = 1 end
	countBox.Text = tostring(math.min(maxCount, MAX_PER_LINE))
end)

addBtn.MouseButton1Click:Connect(function()
	if not selectedItem then setStatus("No item selected.", true) return end
	local count = tonumber(countBox.Text)
	if not count or count <= 0 then setStatus("Enter a valid count.", true) return end
	count = math.floor(count)
	local isSingle = selectedItem.category == "HarvestedFruits" or selectedItem.category == "Pets"
	local maxAllowed = if isSingle then 1 else math.min(selectedItem.amount, MAX_PER_LINE)
	if count > maxAllowed then setStatus(string.format("Max for this item: %d", maxAllowed), true) return end
	local key = selectedItem.cartKey
	local existing = cart[key]
	if existing then
		local newTotal = existing.count + count
		if not isSingle and newTotal > maxAllowed then setStatus(string.format("Max for this item: %d", maxAllowed), true) return end
		existing.count = newTotal
	else
		if cartTotals() >= MAX_BATCH_TYPES then setStatus(string.format("Cart full (%d item types max).", MAX_BATCH_TYPES), true) return end
		cart[key] = { category = selectedItem.category, itemKey = selectedItem.itemKey, count = count, label = selectedItem.label:gsub(" x%d+$", ""), entryValue = selectedItem.entryValue }
	end
	refreshCartUI()
	setStatus("Added to cart.", false)
end)

sendBtn.MouseButton1Click:Connect(function()
	if sending then return end
	if not resolvedUserId and not resolveRecipient() then return end
	local _, total = cartTotals()
	if total == 0 then setStatus("Cart is empty.", true) return end
	local payload = {}
	for _, entry in cart do table.insert(payload, { Category = entry.category, ItemKey = entry.itemKey, Count = entry.count }) end
	sending = true
	sendBtn.Text = "Sending..."
	sendBtn.BackgroundColor3 = C.accentDark
	task.spawn(function()
		local ok, success, message = pcall(function() return Networking.Mailbox.SendBatch:Fire(resolvedUserId, payload, "") end)
		sending = false
		sendBtn.Text = "Send Batch"
		sendBtn.BackgroundColor3 = C.accent
		if not ok then setStatus("Remote error — try again.", true) return end
		if success then
			setStatus(string.format("Successfully sent mail to UserID: %d (%d items)", resolvedUserId, total), false)
			table.clear(cart)
			refreshCartUI()
			refreshItems()
		else
			setStatus(if message and message ~= "" then message else "Could not send gift.", true)
		end
	end)
end)

task.spawn(function()
	while gui.Parent do
		if autoAcceptEnabled then
			pcall(function()
				local ok, inbox = pcall(function() return Networking.Mailbox.OpenInbox:Fire() end)
				if ok and typeof(inbox) == "table" then
					for mailId in inbox do pcall(function() Networking.Mailbox.Claim:Fire(mailId) end) task.wait(0.15) end
				end
			end)
		end
		task.wait(AUTO_CLAIM_INTERVAL)
	end
end)

task.spawn(function()
	local function attach(replica)
		replica:OnChange(function(_, path)
			if typeof(path) == "table" and path[1] == "Inventory" then refreshItems() end
		end)
	end
	local replica = PlayerStateClient:GetLocalReplica()
	if replica then attach(replica) else PlayerStateClient:OnLocalReplica(attach) end
end)

do
	local dragging, dragStart, startPos = false, nil, nil
	header.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true dragStart = input.Position startPos = root.Position
		end
	end)
	header.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if not dragging then return end
		if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
		local delta = input.Position - dragStart
		root.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end)
end

minimizeBtn.MouseButton1Click:Connect(function()
	minimized = not minimized
	if minimized then
		savedSize = root.Size
		closeDropdown()
		TweenService:Create(root, TweenInfo.new(0.15), { Size = UDim2.fromOffset(320, 54) }):Play()
		body.Visible = false
	else
		body.Visible = true
		TweenService:Create(root, TweenInfo.new(0.15), { Size = savedSize }):Play()
	end
end)

closeBtn.MouseButton1Click:Connect(function() closeDropdown() gui:Destroy() end)
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.RightShift then
		root.Visible = not root.Visible
		if not root.Visible then closeDropdown() end
	end
end)

refreshCategories()
refreshItems()
refreshCartUI()
