local MailboxItemCatalog
do
	local controllers = LocalPlayer:WaitForChild("PlayerScripts"):WaitForChild("Controllers")
	local mailbox = controllers:WaitForChild("MailboxController", 10)
	if mailbox then
		local catalog = mailbox:FindFirstChild("MailboxItemCatalog")
		if catalog then
			local ok, mod = pcall(require, catalog)
			if ok then MailboxItemCatalog = mod end
		end
	end
end

if not MailboxItemCatalog then
	MailboxItemCatalog = {
		Categories = { "Seeds", "HarvestedFruits" },
		IsGiftable = function() return true end,
		Resolve = function(_, key) return key, "" end,
		GetHeadshot = function(userId)
			local ok, url = pcall(function()
				return Players:GetUserThumbnailAsync(userId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
			end)
			return ok and url or ""
		end,
	}
end

