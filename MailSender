local function openDropdown(anchorBtn, options, onPick)
	closeDropdown()
	if #options == 0 then return end
	local btnPos = anchorBtn.AbsolutePosition
	local rootPos = root.AbsolutePosition
	local relX = btnPos.X - rootPos.X
	local relY = btnPos.Y - rootPos.Y + anchorBtn.AbsoluteSize.Y + 4
	local menuH = math.min(#options * 34 + 8, 168)
	dropdownMenu.Size = UDim2.fromOffset(anchorBtn.AbsoluteSize.X, menuH)
	dropdownMenu.Position = UDim2.fromOffset(relX, relY)
	for _, opt in options do
		local row = makeButton(dropdownScroll, {
			Size = UDim2.new(1, 0, 0, 30), BackgroundColor3 = C.field,
			Text = opt.label or tostring(opt), Font = Enum.Font.Gotham, TextSize = 13,
			TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 53,
		})
		pad(row, 0, 8, 0, 10)
		row.MouseButton1Click:Connect(function() closeDropdown() onPick(opt) end)
	end
	dropdownScrim.Visible = true
	dropdownMenu.Visible = true
end

local function makeDropdown(labelText, defaultText)
	local wrap = fieldBlock(labelText, 58)
	local btn = makeButton(wrap, {
		Size = UDim2.new(1, 0, 0, 34), Position = UDim2.fromOffset(0, 20),
		BackgroundColor3 = C.field, Text = defaultText .. "  v", Font = Enum.Font.Gotham,
		TextXAlignment = Enum.TextXAlignment.Left,
	})
	pad(btn, 0, 10, 0, 10)
	btn.AutoButtonColor = false
	local selected = defaultText
	local options = {}
	local onPickFn
	local function setText(text) selected = text btn.Text = text .. "  v" end
	btn.MouseButton1Click:Connect(function()
		openDropdown(btn, options, function(opt) setText(opt.label or opt) if onPickFn then onPickFn(opt) end end)
	end)
	return {
		setOptions = function(newOptions) options = newOptions end,
		setText = setText,
		getSelected = function() return selected end,
		onChanged = function(fn) onPickFn = fn end,
	}
end

