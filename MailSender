local resolvedUserId, resolvedDisplayName, lookupRunning = nil, nil, false
local statusLabel

local function setStatus(text, isError)
	statusLabel.Text = text
	statusLabel.TextColor3 = isError and C.error or C.success
end

local function setAvatar(userId)
	avatarPlaceholder.Visible = true
	avatarImage.Image = ""
	task.spawn(function()
		local url = MailboxItemCatalog.GetHeadshot(userId)
		if url ~= "" and avatarImage.Parent then
			avatarImage.Image = url
			avatarPlaceholder.Visible = false
		end
	end)
end

local function clearRecipient()
	resolvedUserId, resolvedDisplayName = nil, nil
	avatarImage.Image = ""
	avatarPlaceholder.Visible = true
	recipientInfo.Text = "No recipient set"
	recipientInfo.TextColor3 = C.muted
end

local function resolveRecipient()
	if lookupRunning then return false end
	local raw = recipientBox.Text:gsub("^%s*@?", ""):gsub("%s+$", "")
	if raw == "" then clearRecipient() setStatus("Enter a username or UserId.", true) return false end
	local asNumber = tonumber(raw)
	if asNumber and asNumber > 0 then
		resolvedUserId = asNumber
		resolvedDisplayName = "User" .. tostring(asNumber)
		setAvatar(asNumber)
		recipientInfo.Text = string.format("@%s  (ID: %d)", resolvedDisplayName, asNumber)
		recipientInfo.TextColor3 = C.text
		setStatus("Recipient set.", false)
		return true
	end
	if #raw < 3 or #raw > 20 or not raw:match("^[%w_]+$") then
		setStatus("Invalid username format.", true)
		return false
	end
	lookupRunning = true
	setRecipientBtn.Text = "..."
	setRecipientBtn.BackgroundColor3 = C.accentDark
	local ok, userId, displayName = pcall(function() return Networking.Mailbox.LookupPlayer:Fire(raw) end)
	lookupRunning = false
	setRecipientBtn.Text = "Set"
	setRecipientBtn.BackgroundColor3 = C.accent
	if not ok or typeof(userId) ~= "number" or userId <= 0 then
		clearRecipient()
		setStatus("Player not found.", true)
		return false
	end
	resolvedUserId = userId
	resolvedDisplayName = (displayName and displayName ~= "") and displayName or raw
	setAvatar(userId)
	recipientInfo.Text = string.format("@%s  (ID: %d)", resolvedDisplayName, userId)
	recipientInfo.TextColor3 = C.text
	setStatus("Recipient set.", false)
	return true
end

