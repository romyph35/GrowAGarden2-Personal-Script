	"Seeds", "HarvestedFruits", "Sprinklers", "WateringCans", "Mushrooms",
	"Gnomes", "Raccoons", "Crates", "SeedPacks", "Trowels", "Props", "Pets", "EmptyPots",
}

local categorySet = {}
for _, name in MailboxItemCatalog.Categories do categorySet[name] = true end

local function isGiftableCategory(cat)
	return categorySet[cat] == true and MailboxItemCatalog.IsGiftable(cat)
end

local function getInventory()
	local replica = PlayerStateClient:GetLocalReplica()
	if not replica or typeof(replica.Data) ~= "table" then return nil end
	local inv = replica.Data.Inventory
	return typeof(inv) == "table" and inv or nil
end

local function isGiftableEntry(category, itemKey, entryValue)
	if not isGiftableCategory(category) then return false end
	if category == "HarvestedFruits" then
		return typeof(entryValue) == "table" and entryValue.Id ~= nil
	end
	if category == "Pets" then
		return typeof(entryValue) == "table" and entryValue.Id ~= nil and entryValue.Equipped ~= true
	end
	return typeof(entryValue) == "number" and entryValue > 0
end

local function formatItemLabel(category, itemKey, entryValue, amount)
	local displayName = MailboxItemCatalog.Resolve(category, itemKey, entryValue)
	if category == "HarvestedFruits" or category == "Pets" then return displayName end
	return string.format("%s x%d", displayName, amount)
end

local function scanCategory(inventory, category)
	local bucket = inventory[category]
	local list = {}
	if typeof(bucket) ~= "table" then return list end
	if category == "HarvestedFruits" or category == "Pets" then
		for itemKey, entryValue in bucket do
			if isGiftableEntry(category, itemKey, entryValue) then
				table.insert(list, {
					category = category, itemKey = itemKey, entryValue = entryValue,
					amount = 1, label = formatItemLabel(category, itemKey, entryValue, 1),
					cartKey = category .. ":" .. tostring(itemKey),
				})
			end
		end
	else
		for itemKey, count in bucket do
			if isGiftableEntry(category, itemKey, count) then
				table.insert(list, {
					category = category, itemKey = itemKey, entryValue = nil,
					amount = count, label = formatItemLabel(category, itemKey, nil, count),
					cartKey = category .. ":" .. tostring(itemKey),
				})
			end
		end
	end
	table.sort(list, function(a, b) return a.label:lower() < b.label:lower() end)
	return list
end

local function corner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 8)
	c.Parent = parent
	return c
end

local function stroke(parent, color, thickness)
	local s = Instance.new("UIStroke")
	s.Color = color or C.stroke
	s.Thickness = thickness or 1
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = parent
	return s
end

local function pad(parent, t, r, b, l)
	local p = Instance.new("UIPadding")
	p.PaddingTop = UDim.new(0, t or 8)
	p.PaddingRight = UDim.new(0, r or 8)
	p.PaddingBottom = UDim.new(0, b or 8)
	p.PaddingLeft = UDim.new(0, l or 8)
	p.Parent = parent
	return p
end

local function makeLabel(parent, props)
