local fruitCart = {}

local function rebuildFruitCart()
    for _, c in fruitCartScroll:GetChildren() do if c:IsA("Frame") then c:Destroy() end end
    local n = #fruitCart
    fruitCartEmpty.Visible = n == 0
    local totalVal = 0
    for _, e in fruitCart do
        local v = calcFruitValue(e.itemKey, e.sizeMult, e.mutation, e.decay)
        if v then totalVal += v end
    end
    local valStr = totalVal > 0 and ("  "..fmtVal(totalVal)) or ""
    fruitCartLbl.Text       = ("Cart  %d/%d%s"):format(n, MAX_FRUIT_CART, valStr)
    fruitCartLbl.TextColor3 = n >= MAX_FRUIT_CART and C.red or C.text

    for i, entry in ipairs(fruitCart) do
        local val    = calcFruitValue(entry.itemKey, entry.sizeMult, entry.mutation, entry.decay)
        local valTxt = val and fmtVal(val) or ""
        local row    = Instance.new("Frame")
        row.BackgroundColor3 = C.field
        row.Size             = UDim2.new(1,0,0,BTN_H-2)
        row.BorderSizePixel  = 0
        row.LayoutOrder      = i
        row.Parent           = fruitCartScroll
        mkCorner(row, 5)
        mkLabel(row, {
            Text         = entry.label,
            Size         = UDim2.new(1,-58,0.55,0),
            Position     = UDim2.fromOffset(7,2),
            TextColor3   = C.text,
            TextSize     = FS_SM,
            TextTruncate = Enum.TextTruncate.AtEnd,
        })
        if valTxt ~= "" then
            mkLabel(row, {
                Text       = valTxt,
                Size       = UDim2.new(1,-58,0.45,0),
                Position   = UDim2.new(0,7,0.55,0),
                TextColor3 = C.green,
                TextSize   = math.max(FS_SM-1,9),
                Font       = Enum.Font.GothamBold,
            })
        end
        local xb = mkBtn(row, {
