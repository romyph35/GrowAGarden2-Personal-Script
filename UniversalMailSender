local function buildResults(query)
    for _, c in resultsScroll:GetChildren() do
        if c:IsA("TextButton") then c:Destroy() end
    end
    local q = query:lower():gsub("%s+","")
    local filtered = currentFruits
    if filterType then
        filtered = {}
        for _, f in currentFruits do
            if f.itemKey == filterType then table.insert(filtered, f) end
        end
    end
    local results = {}
    for _, f in filtered do
        if q == "" or f.label:lower():gsub("%s+",""):find(q,1,true) then
            table.insert(results, f)
        end
    end
    noResultsLbl.Visible = #results == 0
    local grand = 0
    for _, f in results do
        local v = calcFruitValue(f.itemKey, f.sizeMult, f.mutation, f.decay)
        if v then grand += v end
    end
    valBarTxt.Text = "Total: "..fmtVal(grand)
    valBarCnt.Text = #results.." fruit"..(#results==1 and "" or "s")
    for i, fruit in ipairs(results) do
        local val    = calcFruitValue(fruit.itemKey, fruit.sizeMult, fruit.mutation, fruit.decay)
        local valTxt = val and ("  "..fmtVal(val)) or ""
