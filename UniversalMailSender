-- Mail send logic
local mailSending = false
connectButton(mailSendBtn, function()
    if mailSending then return end
    if not resolvedId then
        if not resolveRecip() then setStatus("Set a recipient first.", true); return end
    end
    if #mailCart == 0 then setStatus("Cart is empty.", true); return end
    mailSending = true
    mailSendBtn.Text             = "Sending..."
    mailSendBtn.BackgroundColor3 = C.aDark
    mailSendBtn.Active           = false
    task.spawn(function()
        local snapshot = {}
        for _, e in ipairs(mailCart) do table.insert(snapshot, e) end
        local batch = {}
        for _, e in ipairs(snapshot) do
            table.insert(batch, {
                Category = e.isPot and "EmptyPots" or e.category,
                ItemKey  = e.itemKey,
                Count    = e.qty or 1,
            })
        end
        -- split into SERVER_CHUNK sized pieces
        local chunks = {}
        for i = 1, #batch, SERVER_CHUNK do
            local c = {}
            for j = i, math.min(i+SERVER_CHUNK-1, #batch) do table.insert(c, batch[j]) end
            table.insert(chunks, c)
        end
        local sent, failed = 0, false
        for i, chunk in ipairs(chunks) do
            if i > 1 then
                for cd = BATCH_DELAY, 1, -1 do
                    setStatus(("⏳ Cooldown %ds · Batch %d/%d"):format(cd,i,#chunks), false)
                    task.wait(1)
                end
            end
            setStatus(("Batch %d/%d · sending..."):format(i,#chunks), false)
            local ok, success, msg = pcall(function()
                return Networking.Mailbox.SendBatch:Fire(resolvedId, chunk, "")
            end)
            if ok and success then
                sent += #chunk
                setStatus(("Batch %d/%d done · %d sent"):format(i,#chunks,sent), false)
            else
                local reason = (not ok and "Remote error")
                    or (type(msg)=="string" and msg~="" and msg) or "Send failed"
                setStatus(("Batch %d failed: %s"):format(i,reason), true)
                failed = true; break
            end
        end
        mailSending = false
        mailSendBtn.Active           = true
        mailSendBtn.Text             = "📨  Send Mail"
        mailSendBtn.BackgroundColor3 = C.accent
        if sent > 0 then
            local labels = {}
            for i = 1, sent do
                local e = snapshot[i]
                if e then table.insert(labels, e.displayName.." ×"..(e.qty or 1)) end
            end
            addHistory(resolvedName, resolvedId, labels, sent, "Mail")
            sendWebhook(resolvedName, resolvedId, labels, sent, "Mail")
            table.clear(mailCart); rebuildMailCart()
        end
        if not failed then
            setStatus(("Done! Sent %d item(s) to @%s"):format(sent, resolvedName or "?"), false)
        end
    end)
end)
connectButton(mailClearBtn,   function() table.clear(mailCart); rebuildMailCart(); setStatus("Cart cleared.",false) end)
