-- Resolve logic
local resolvedId, resolvedName, lookupBusy = nil, nil, false

local function setAvatar(uid)
    avPH.Visible = true; avImg.Image = ""
    task.spawn(function()
        local url = getHeadshot(uid)
        if url ~= "" and avImg.Parent then avImg.Image = url; avPH.Visible = false end
    end)
end
local function clearRecip()
    resolvedId, resolvedName = nil, nil
    avImg.Image = ""; avPH.Visible = true
    recInfo.Text = "No recipient set"; recInfo.TextColor3 = C.muted
end
local function resolveRecip()
    if lookupBusy then return false end
    local raw = recBox.Text:gsub("^%s*@?",""):gsub("%s+$","")
    if raw == "" then clearRecip(); return false end
    local num = tonumber(raw)
    if num and num > 0 then
        resolvedId = num; resolvedName = "User"..num; setAvatar(num)
        recInfo.Text = ("@%s  (ID: %d)"):format(resolvedName, num)
        recInfo.TextColor3 = C.text; return true
    end
    if #raw < 3 or #raw > 20 or not raw:match("^[%w_]+$") then return false end
    lookupBusy = true; setRecBtn.Text = "..."; setRecBtn.BackgroundColor3 = C.aDark
    local ok, uid = pcall(function()
        return Networking.Mailbox.LookupPlayer:Fire(raw)
    end)
    lookupBusy = false; setRecBtn.Text = "Set"; setRecBtn.BackgroundColor3 = C.accent
    if not ok or type(uid) ~= "number" or uid <= 0 then
        clearRecip(); recInfo.Text = "Player not found"; recInfo.TextColor3 = C.red; return false
    end
    resolvedId = uid; resolvedName = raw; setAvatar(uid)
    recInfo.Text = ("@%s  (ID: %d)"):format(resolvedName, uid)
    recInfo.TextColor3 = C.text; return true
end

connectButton(setRecBtn, resolveRecip)
recBox.FocusLost:Connect(function(e) if e then resolveRecip() end end)
recBox:GetPropertyChangedSignal("Text"):Connect(function()
    if resolvedId then
        resolvedId, resolvedName = nil, nil
        recInfo.Text = "Press Set to confirm"; recInfo.TextColor3 = C.muted
    end
end)

