-- AUTO-WATCH INVENTORY (fruits)
-- ════════════════════════════════════════
task.spawn(function()
    local function watch(c)
        if not c then return end
        c.ChildAdded:Connect(function(child)
            local isFruitItem = child:GetAttribute("Fruit")
                or (child:GetAttribute("PottedPlant") and child:GetAttribute("HasFruits"))
            if isFruitItem then task.wait(0.15); refreshFruits() end
        end)
        c.ChildRemoved:Connect(function(child)
            local isFruitItem = child:GetAttribute("Fruit")
                or (child:GetAttribute("PottedPlant") and child:GetAttribute("HasFruits"))
            if isFruitItem then
                task.wait(0.15); refreshFruits()
                local rid = child:GetAttribute("Id")
                if rid then
                    for i = #fruitCart, 1, -1 do
                        if fruitCart[i].id == rid then table.remove(fruitCart, i) end
                    end
                    rebuildFruitCart()
                end
            end
        end)
    end
    watch(LocalPlayer:FindFirstChild("Backpack"))
    if LocalPlayer.Character then watch(LocalPlayer.Character) end
    LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.5); watch(char)
        watch(LocalPlayer:FindFirstChild("Backpack"))
        refreshFruits()
    end)
    refreshFruits(); rebuildFruitCart()
end)

