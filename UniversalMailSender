-- TOUCH-SAFE BUTTON
-- ════════════════════════════════════════
local TOUCH_MAX_DIST = 15
local function connectButton(btn, cb)
    local sp = nil
    btn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            sp = Vector2.new(inp.Position.X, inp.Position.Y)
        end
    end)
    btn.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            if sp then
                local d = (Vector2.new(inp.Position.X, inp.Position.Y)-sp).Magnitude
                sp = nil
                if d <= TOUCH_MAX_DIST then task.spawn(cb) end
            end
        end
    end)
end

