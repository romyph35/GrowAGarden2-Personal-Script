-- Fruit send logic
local fruitSending = false
connectButton(sendAllFruitBtn, function()
    if fruitSending then return end
    if not resolvedId then
        if not resolveRecip() then setStatus("Set a recipient first.", true); return end
    end
    if #fruitCart == 0 then setStatus("Cart is empty.", true); return end

    local snapshot = {}
    for _, e in ipairs(fruitCart) do table.insert(snapshot, e) end
    local chunks = {}
    for i = 1, #snapshot, SERVER_CHUNK do
        local chunk = {}
        for j = i, math.min(i+SERVER_CHUNK-1, #snapshot) do
            table.insert(chunk, {
                Category = snapshot[j].isPot and "EmptyPots" or "HarvestedFruits",
                ItemKey  = snapshot[j].id,
                Count    = 1,
            })
        end
        table.insert(chunks, chunk)
    end

    fruitSending = true
    sendAllFruitBtn.Text             = "Sending..."
    sendAllFruitBtn.BackgroundColor3 = C.aDark
    sendAllFruitBtn.Active           = false

    task.spawn(function()
        local sent, failed = 0, false
        for i, chunk in ipairs(chunks) do
            if i > 1 then
                for cd = BATCH_DELAY, 1, -1 do
                    if not fruitSending then break end
                    setStatus(("⏳ Cooldown %ds · Batch %d/%d"):format(cd,i,#chunks), false)
                    task.wait(1)
                end
            end
            if not fruitSending then
                setStatus(("Stopped. Sent %d/%d"):format(sent,#snapshot), true); break
            end
            setStatus(("Batch %d/%d · sending %d fruit(s)..."):format(i,#chunks,#chunk), false)
            local ok, success, msg = pcall(function()
                return Networking.Mailbox.SendBatch:Fire(resolvedId, chunk, "")
            end)
            if ok and success then
                sent += #chunk
                setStatus(("Batch %d/%d done · %d/%d"):format(i,#chunks,sent,#snapshot), false)
            else
                local reason = (not ok and "Remote error")
                    or (type(msg)=="string" and msg~="" and msg) or "Send failed"
                setStatus(("Batch %d failed: %s  (%d/%d)"):format(i,reason,sent,#snapshot), true)
                failed = true; break
            end
        end
        fruitSending = false
        sendAllFruitBtn.Active           = true
        sendAllFruitBtn.Text             = "🍎  Send Fruits (auto-batched)"
        sendAllFruitBtn.BackgroundColor3 = C.orange
        if sent > 0 then
            local labels = {}
            for i = 1, sent do
                local e = snapshot[i]; if e then table.insert(labels, e.label) end
            end
            addHistory(resolvedName, resolvedId, labels, sent, "Fruits")
            sendWebhook(resolvedName, resolvedId, labels, sent, "Fruits")
            for _ = 1, sent do table.remove(fruitCart, 1) end
            rebuildFruitCart()
        end
        if not failed then
            setStatus(("Done! Sent %d fruit(s) to @%s"):format(sent, resolvedName or "?"), false)
        end
        refreshFruits()
    end)
end)

-- History rebuild (fruits)
local function rebuildFruitHistory()
    for _, c in fHistScroll:GetChildren() do if c:IsA("Frame") then c:Destroy() end end
    -- filter to only Fruits tab entries
    local fruitsHist = {}
    for _, e in mailHistory do
        if e.tab == "Fruits" then table.insert(fruitsHist, e) end
    end
    fHistEmpty.Visible = #fruitsHist == 0
    for i, entry in ipairs(fruitsHist) do
        local card = Instance.new("Frame")
        card.BackgroundColor3 = C.histRow
        card.BorderSizePixel  = 0
        card.Size             = UDim2.new(1,0,0,0)
        card.AutomaticSize    = Enum.AutomaticSize.Y
        card.LayoutOrder      = i
        card.Parent           = fHistScroll
        mkCorner(card, 6); mkStroke(card, C.stroke, 1); mkPad(card, 6, 8, 6, 8)
        mkList(card, 3)

        local hrow = Instance.new("Frame")
        hrow.BackgroundTransparency = 1
        hrow.Size        = UDim2.new(1,0,0,16)
        hrow.LayoutOrder = 1
        hrow.Parent      = card

        mkLabel(hrow, { Text=fmtTime(entry.time), Size=UDim2.new(0.35,0,1,0), TextSize=FS_SM, TextColor3=C.muted })
        mkLabel(hrow, {
            Text     = "→ @"..entry.recipient,
            Size     = UDim2.new(0.45,0,1,0),
            Position = UDim2.new(0.35,0,0,0),
            TextSize = FS_SM,
            TextColor3 = C.orange,
            Font     = Enum.Font.GothamBold,
        })
        mkLabel(hrow, {
            Text           = "×"..entry.count,
            Size           = UDim2.new(0.2,0,1,0),
            Position       = UDim2.new(0.8,0,0,0),
            TextSize       = FS_SM,
            TextColor3     = C.green,
            Font           = Enum.Font.GothamBold,
            TextXAlignment = Enum.TextXAlignment.Right,
        })
        local MAX_SHOW = 5
        for j = 1, math.min(#entry.items, MAX_SHOW) do
            mkLabel(card, {
                Text         = "  "..entry.items[j],
                Size         = UDim2.new(1,0,0,14),
                TextSize     = FS_SM,
                TextColor3   = C.text,
                Font         = Enum.Font.Gotham,
                TextTruncate = Enum.TextTruncate.AtEnd,
                LayoutOrder  = j+1,
            })
        end
        if #entry.items > MAX_SHOW then
            mkLabel(card, {
                Text       = ("  ...+%d more"):format(#entry.items-MAX_SHOW),
                Size       = UDim2.new(1,0,0,14),
                TextSize   = FS_SM,
                TextColor3 = C.muted,
                Font       = Enum.Font.Gotham,
                LayoutOrder = MAX_SHOW+2,
            })
        end
    end
end

