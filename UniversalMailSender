-- ════════════════════════════════════════
-- INVENTORY SCANNER
-- Returns catalog items from replica Data
-- ════════════════════════════════════════
-- Categories we show in the Mail tab (non-fruit)
local MAIL_CATEGORIES = {
    "Seeds","WateringCans","Sprinklers","Mushrooms","Gnomes",
    "Raccoons","Crates","GuildCrates","SeedPacks","Eggs",
    "Trowels","Props","EmptyPots","Pets","PowerHoses",
}

local function getCatalogItems()
    local list = {}
    if not PlayerStateClient then return list end
    local replica = PlayerStateClient:GetLocalReplica()
    if not replica then return list end
    local inv = replica.Data and replica.Data.Inventory
    if type(inv) ~= "table" then return list end

    for _, cat in MAIL_CATEGORIES do
        local catData = inv[cat]
        if type(catData) == "table" then
            for itemKey, value in catData do
                local qty = 0
                if type(value) == "number" then
                    qty = value
                elseif type(value) == "table" then
                    -- pets / fruits stored as individual entries
                    qty = 1
                end
                if qty > 0 then
                    local displayName, image = itemKey, ""
                    if MailboxItemCatalog then
                        local ok2, dn, img = pcall(MailboxItemCatalog.Resolve,
                            MailboxItemCatalog, cat, itemKey, value)
                        if ok2 and dn then displayName = dn end
                        if ok2 and img then image = img end
                    end
                    table.insert(list, {
                        category    = cat,
                        itemKey     = itemKey,
                        displayName = displayName,
                        image       = image,
                        qty         = qty,
                        entryValue  = value,
                    })
                end
            end
        end
    end
    table.sort(list, function(a,b)
        if a.category ~= b.category then return a.category < b.category end
        return a.displayName:lower() < b.displayName:lower()
    end)
    return list
end

-- ════════════════════════════════════════
-- POTTED PLANT SCANNER  (PlantInPot for Mail tab)
-- Attributes: PottedPlant=true, PlantName, Id, SizeMultiplier, FruitName, Variant
-- ════════════════════════════════════════
local function getPottedPlants()
    local list, seen = {}, {}
    local function scan(c)
        if not c then return end
        for _, item in c:GetChildren() do
            if item:GetAttribute("PottedPlant") == true and not seen[item] then
                seen[item] = true
                local plantName = item:GetAttribute("PlantName") or item.Name
                local fruitName = item:GetAttribute("FruitName") or ""
                local variant   = item:GetAttribute("Variant") or "Normal"
                local sizeMult  = item:GetAttribute("SizeMultiplier") or 1
                local id        = item:GetAttribute("Id")
                local hasFruits = item:GetAttribute("HasFruits")
                local lbl = plantName
                if variant and variant ~= "" and variant ~= "Normal" then
                    lbl = variant.." "..lbl
                end
                table.insert(list, {
                    id          = id,
                    label       = lbl,
                    plantName   = plantName,
                    fruitName   = fruitName,
                    variant     = variant,
                    sizeMult    = sizeMult,
                    hasFruits   = hasFruits,
                    isPottedPlant = true,
                })
            end
        end
    end
    scan(LocalPlayer.Character)
    scan(LocalPlayer:FindFirstChild("Backpack"))
    table.sort(list, function(a,b) return a.label:lower() < b.label:lower() end)
    return list
end

-- ════════════════════════════════════════
-- FRUIT SCANNER  (harvested + fruit-pot)
-- ════════════════════════════════════════
local function getFruits()
    local list, seen = {}, {}
    local function scan(c)
        if not c then return end
        for _, item in c:GetChildren() do
            if seen[item] then continue end
            local fn = item:GetAttribute("Fruit")
            -- Also pick up FruitPot items (PottedPlant + HasFruits)
            local isPot = item:GetAttribute("PottedPlant") == true
                       and item:GetAttribute("HasFruits") == true
            if fn or isPot then
                seen[item] = true
                local fruitName = fn or item:GetAttribute("FruitName") or item.Name
                local mut       = item:GetAttribute("Mutation")
                            or item:GetAttribute("Variant") or ""
                local wt        = item:GetAttribute("Weight")
                local id        = item:GetAttribute("Id")
                local sizeMult  = item:GetAttribute("SizeMultiplier") or 1
                local decay     = item:GetAttribute("DecayAlpha") or 0
                if mut == "Normal" then mut = "" end
                local lbl = fruitName
                if mut and mut ~= "" then lbl = mut.." "..fruitName end
                if wt then lbl = lbl..string.format(" (%.1fg)", wt) end
                if isPot then lbl = "🪴 "..lbl end
                table.insert(list, {
                    id       = id,
                    label    = lbl,
                    itemKey  = fruitName,
                    mutation = mut,
                    weight   = wt,
                    sizeMult = sizeMult,
                    decay    = decay,
                    isPot    = isPot,
                })
            end
        end
    end
    scan(LocalPlayer.Character)
    scan(LocalPlayer:FindFirstChild("Backpack"))
    table.sort(list, function(a,b) return a.label:lower() < b.label:lower() end)
    return list
end

