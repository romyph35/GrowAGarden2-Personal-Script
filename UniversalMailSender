-- refreshFruits (now defined)
refreshFruits = function()
    currentFruits = getFruits()
    if #currentFruits == 0 then
        pickBtn.Text = "No fruits in inventory"; selectedFruit = nil; return
    end
    local filtered = currentFruits
    if filterType then
        filtered = {}
        for _, f in currentFruits do
            if f.itemKey == filterType then table.insert(filtered, f) end
        end
    end
    if #filtered == 0 then
        pickBtn.Text = "No "..(filterType or "fruits").." found"
        selectedFruit = nil; return
    end
    if selectedFruit then
        local found = false
        for _, f in filtered do
            if f.id == selectedFruit.id then selectedFruit = f; found = true; break end
        end
        if not found then selectedFruit = filtered[1] end
    else
        selectedFruit = filtered[1]
    end
    pickBtn.Text = selectedFruit.label
end

-- Add one
local function doAddOneFruit()
    refreshFruits()
    if not selectedFruit    then setStatus("No fruit selected.",  true); return end
    if not selectedFruit.id then setStatus("Fruit has no Id.",    true); return end
    if #fruitCart >= MAX_FRUIT_CART then setStatus("Cart full ("..MAX_FRUIT_CART..").", true); return end
    for _, e in fruitCart do
        if e.id == selectedFruit.id then setStatus("Already in cart.", true); return end
    end
    table.insert(fruitCart, {
        id       = selectedFruit.id,
        label    = selectedFruit.label,
        itemKey  = selectedFruit.itemKey,
        mutation = selectedFruit.mutation,
        weight   = selectedFruit.weight,
        sizeMult = selectedFruit.sizeMult,
        decay    = selectedFruit.decay,
        isPot    = selectedFruit.isPot,
    })
    rebuildFruitCart(); setStatus("Added: "..selectedFruit.label, false)
end
connectButton(addOneBtn, doAddOneFruit)

-- Add all
connectButton(addAllFruitBtn, function()
    refreshFruits(); local added = 0
    for _, f in currentFruits do
        if #fruitCart >= MAX_FRUIT_CART then break end
        local typeMatch = filterType == nil or f.itemKey == filterType
        if typeMatch and f.id then
            local dup = false
            for _, e in fruitCart do if e.id == f.id then dup=true; break end end
            if not dup then
                table.insert(fruitCart, {
                    id=f.id, label=f.label, itemKey=f.itemKey,
                    mutation=f.mutation, weight=f.weight,
                    sizeMult=f.sizeMult, decay=f.decay, isPot=f.isPot,
                })
                added += 1
            end
        end
    end
    rebuildFruitCart()
    local ts = filterType and (' "'..filterType..'"') or ""
    setStatus(added>0 and ("Added %d%s fruits"):format(added,ts) or "Nothing new to add.", added==0)
end)
