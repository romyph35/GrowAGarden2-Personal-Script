-- ════════════════════════════════════════
-- DISCORD WEBHOOK
-- ════════════════════════════════════════
local function sendWebhook(rName, rId, labels, count, tabName)
    if WEBHOOK_URL == "" or not httpReq then return end
    task.spawn(function()
        local lines = {}
        for i, lbl in ipairs(labels) do
            if i > 25 then table.insert(lines, ("...+%d more"):format(#labels-25)); break end
            table.insert(lines, lbl)
        end
        local function esc(s)
            return tostring(s):gsub('"','\\"'):gsub("\n","\\n")
        end
        local body = ('{"username":"Universal Mail Sender","embeds":[{'..
            '"title":"Mail Sent · %s","color":3832063,"fields":['..
            '{"name":"Sender","value":"%s","inline":true},'..
            '{"name":"Recipient","value":"@%s (ID: %s)","inline":true},'..
            '{"name":"Sent","value":"**%d item(s)**","inline":true},'..
            '{"name":"Items","value":"```\\n%s\\n```","inline":false}'..
            '],"footer":{"text":"UniversalMailSender"},"timestamp":"%s"}]}'):format(
            esc(tabName or "Mail"),
            esc(LocalPlayer.DisplayName.." (@"..LocalPlayer.Name..")"),
            esc(rName), esc(tostring(rId or "?")), count,
            esc(#lines>0 and table.concat(lines,"\n") or "—"),
            os.date("!%Y-%m-%dT%H:%M:%SZ"))
        pcall(httpReq, {
            Url     = WEBHOOK_URL,
            Method  = "POST",
            Headers = {["Content-Type"]="application/json"},
            Body    = body,
        })
    end)
end

